LOGFILE=""
FAILED=0
FAIL_MSG=""
EXIT_CODE=1
PRINT_EFFCONF=0
CONFIG_WRITE_ROTATE=0
CONFIG_WRITE_PATH=""

# Metadata cache for performance optimization
METADATA_CACHE=""

# ===== Section 4: Opinionated defaults ========================================================
