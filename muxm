EAC3_BITRATE_5_1="640k"
EAC3_BITRATE_7_1="768k"
declare -i PARALLEL_AUDIO=0

# ---- Subtitles
SUB_LANG_PREF="eng"
declare -i SUB_INCLUDE_FORCED=1
declare -i SUB_INCLUDE_FULL=1
declare -i SUB_INCLUDE_SDH=1
declare -i SUB_MAX_TRACKS=3

declare -i SUB_ENABLE_OCR=1
SUB_OCR_TOOL="sub2srt"
SUB_OCR_LANG="eng"

# ---- Muxing / output
OUTPUT_EXT="mp4"               # supports mp4|m4v|mov
declare -i MP4_INTERLEAVE_MS=500
TAG_LANGUAGE_DEFAULT="und"
declare -i INCLUDE_AUDIO_TITLES=1

# ---- Operational defaults
declare -i CHECKSUM=0
declare -i DRY_RUN=0
declare -i KEEP_TEMP=0
declare -i KEEP_TEMP_ALWAYS=0
declare -i DISK_FREE_WARN_GB=5

# ---- ffmpeg/ffprobe UX
declare -i FFMPEG_HIDE_BANNER=1
FFMPEG_LOGLEVEL="error"
declare -i FFMPEG_OVERWRITE=1
FFPROBE_LOGLEVEL="error"

# ---- Quick-test toggles
declare -i SKIP_VIDEO=0
declare -i SKIP_AUDIO=0
declare -i SKIP_SUBS=0

# ---- Overrides
AUDIO_TRACK_OVERRIDE=""

# ===== Section 5: Basic helpers ===============================================================
say()  { printf "%s\n" "$@" >&2; }
note() { printf "ℹ️  %s\n" "$@" >&2; }
warn() { printf "⚠️  %s\n" "$@" >&2; }

die()  {
  local code=1
  if [[ $# -gt 1 && "$1" =~ ^[0-9]+$ ]]; then code="$1"; shift; fi
  FAILED=1; EXIT_CODE="$code"; FAIL_MSG="Fatal: $*"
  printf "❌ ERROR: %s\n" "$FAIL_MSG" >&2
  exit "$code"
}

on_error(){
  local lineno="$1" cmd="$2" status="$3"
  FAILED=1
  EXIT_CODE="${EXIT_CODE:-$status}"
  FAIL_MSG="Command failed at line $lineno: $cmd (exit $status)"
  printf "❌ ERROR: %s\n" "$FAIL_MSG" >&2
}

mark_done(){ COMPLETED_STEPS+=("$1"); }

need(){
  command -v "$1" >/dev/null 2>&1 || die 10 "Missing required tool: $1"
}

# Improved realpath that handles non-existent files on all platforms
realpath_fallback(){
  local p="$1"
  
  # Try GNU realpath with -m (allows missing files)
  if command -v realpath >/dev/null 2>&1; then
    if realpath -m "$p" 2>/dev/null; then
      return 0
    fi
  fi
  
  # Fallback for macOS/BSD and systems without realpath
  local dir base
  dir="$(dirname -- "$p")"
  base="$(basename -- "$p")"
  
  if [[ -d "$dir" ]]; then
    echo "$(cd "$dir" 2>/dev/null && pwd)/$base"
  elif [[ "$p" =~ ^/ ]]; then
    # Already absolute
    echo "$p"
  else
    # Make absolute from current directory
    echo "$PWD/$p"
  fi
}

# Improved filesize_pretty - checks native stat first for performance
filesize_pretty(){
  local file="$1"
  # Try native stat first (faster)
  if stat -f "%N %z bytes" /dev/null >/dev/null 2>&1; then
    # macOS/BSD
    stat -f "%N %z bytes" "$file"
  elif stat --printf '%n %s bytes\n' /dev/null >/dev/null 2>&1; then
    # GNU/Linux
    stat --printf '%n %s bytes\n' "$file"
  elif command -v gstat >/dev/null 2>/dev/null; then
    # GNU stat as gstat
    gstat -c "%n %s bytes" "$file"
  else
    ls -lh "$file"
  fi
}

checksum_cmd(){
  command -v sha256sum >/dev/null 2>/dev/null && { echo "sha256sum"; return; }
  command -v shasum >/dev/null 2>/dev/null && { echo "shasum -a 256"; return; }
  echo ""
}

write_checksum(){
  local p="$1" c
  c="$(checksum_cmd)"
  [[ -z "$c" ]] && { warn "Checksum tool not found"; return 0; }
  note "Writing checksum → ${p}.sha256"
  $c "$p" > "${p}.sha256"
}

ffmpeg_has_muxer(){
  local mux="$1"
  ffmpeg -hide_banner -muxers 2>/dev/null | awk '{print $1}' | grep -qx "$mux"
}

# ===== Section 6: Config chain: Defaults → /etc → ~ → project =================================
_muxm_try_source(){
  local f="$1"
  [[ -r "$f" ]] || return 0
  # shellcheck disable=SC1090
  . "$f"
  MUXM_CONFIG_LOADED+=("$f")
}
_muxm_try_source /etc/.muxmrc
_muxm_try_source "$HOME/.muxmrc"
_muxm_try_source "./.muxmrc"

# ===== Section 7: CLI ==========================================================================
USAGE_SHORT="Usage: ${CLI_NAME} [options] <source> [target.${OUTPUT_EXT}]"
print_usage(){
  cat <<EOF
${APP_NAME} v${VERSION} — ${CLI_NAME}

$USAGE_SHORT

Core options:
  -h, --help                  Show help
  -V, --version               Show version
  -K, --keep-temp-always      Keep workdir even on success
  -k, --keep-temp             Keep workdir on failure (default behavior keeps on failure anyway)
  --dry-run                   Print actions and create stub artifacts (no real encode)
  --checksum                  Write sha256 checksum for final output

Video:
  --crf N                     Set CRF (default: ${CRF_VALUE})
  -p, --preset NAME           x265 preset (default: ${PRESET_VALUE})
  --x265-params "..."         Extra/override x265 params
  -l, --level N               HEVC level (e.g., 4.1, 5.1)
  --no-conservative-vbv       Disable VBV guardrails
  --threads N                 ffmpeg threads
  --no-dv                     Disable Dolby Vision extraction/injection
  --no-allow-dv-fallback      If DV handling fails, hard fail (default is fallback to non-DV)

Audio:
  --audio-track N             Force select audio track (0-based, relative to audio streams)
  --audio-lang-pref "eng,..." Language preference order (default: ${AUDIO_LANG_PREF})
  --stereo-bitrate 192k       Stereo AC3 bitrate (default: ${STEREO_BITRATE})
  --no-stereo-fallback        Do not add stereo track when primary is multichannel

Subtitles:
  --no-subtitles              Do not include subtitles
  --no-sub-sdh                Do not include SDH/HI
  --no-ocr                    Disable OCR (PGS will be dropped)
  --ocr-tool TOOL             OCR tool (default: ${SUB_OCR_TOOL})
  --ocr-lang LANG             OCR language (default: ${SUB_OCR_LANG})

Output:
  --output-ext mp4|m4v|mov    Output container family extension (default: ${OUTPUT_EXT})

Quick tests:
  --skip-video                Skip video pipeline
  --skip-audio                Skip audio pipeline
  --skip-subs                 Skip subtitle pipeline

EOF
}

print_version(){ echo "${APP_NAME} v${VERSION} (${CLI_NAME})"; }

is_valid_preset(){
  case "$1" in
    ultrafast|superfast|veryfast|faster|fast|medium|slow|slower|veryslow|placebo) return 0;;
    *) return 1;;
  esac
}

POSITIONALS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) print_usage; exit 0 ;;
    -V|--version) print_version; exit 0 ;;

    --print-effective-config) PRINT_EFFCONF=1; shift ;;

    -k|--keep-temp) KEEP_TEMP=1; shift ;;
    -K|--keep-temp-always) KEEP_TEMP_ALWAYS=1; shift ;;

    --dry-run) DRY_RUN=1; shift ;;
    --checksum) CHECKSUM=1; shift ;;
    --no-checksum) CHECKSUM=0; shift ;;

    --ffmpeg-loglevel) FFMPEG_LOGLEVEL="${2:-}"; shift 2 ;;
    --no-hide-banner) FFMPEG_HIDE_BANNER=0; shift ;;
    --no-overwrite) FFMPEG_OVERWRITE=0; shift ;;
    --ffprobe-loglevel) FFPROBE_LOGLEVEL="${2:-}"; shift 2 ;;
    --threads) THREADS="${2:-}"; shift 2 ;;

    --crf) CRF_VALUE="${2:-}"; shift 2 ;;
    -p|--preset)
      PRESET_VALUE="${2:-}"
      is_valid_preset "$PRESET_VALUE" || die 11 "Invalid preset: $PRESET_VALUE"
      shift 2
      ;;
    --x265-params) X265_PARAMS_BASE="${2:-}"; shift 2 ;;
    -l|--level) LEVEL_VALUE="${2:-}"; shift 2 ;;
    --no-conservative-vbv) CONSERVATIVE_VBV=0; shift ;;
    --no-dv) DISABLE_DV=1; shift ;;
    --allow-dv-fallback) ALLOW_DV_FALLBACK=1; shift ;;
    --no-allow-dv-fallback) ALLOW_DV_FALLBACK=0; shift ;;
    --dv-convert-p81) DV_CONVERT_TO_P81_IF_FAIL=1; shift ;;
    --no-dv-convert-p81) DV_CONVERT_TO_P81_IF_FAIL=0; shift ;;

    --audio-track) AUDIO_TRACK_OVERRIDE="${2:-}"; shift 2 ;;
    --audio-lang-pref) AUDIO_LANG_PREF="${2:-}"; shift 2 ;;
    --stereo-bitrate) STEREO_BITRATE="${2:-}"; shift 2 ;;
    --stereo-fallback) ADD_STEREO_IF_MULTICH=1; shift ;;
    --no-stereo-fallback) ADD_STEREO_IF_MULTICH=0; shift ;;

    --no-subtitles) SUB_INCLUDE_FORCED=0; SUB_INCLUDE_FULL=0; SUB_INCLUDE_SDH=0; shift ;;
    --sub-lang-pref) SUB_LANG_PREF="${2:-}"; shift 2 ;;
    --no-sub-sdh) SUB_INCLUDE_SDH=0; shift ;;
    --ocr-lang) SUB_OCR_LANG="${2:-}"; shift 2 ;;
    --no-ocr) SUB_ENABLE_OCR=0; shift ;;
    --ocr-tool) SUB_OCR_TOOL="${2:-}"; shift 2 ;;

    --skip-video) SKIP_VIDEO=1; shift ;;
    --skip-audio) SKIP_AUDIO=1; shift ;;
    --skip-subs)  SKIP_SUBS=1;  shift ;;

    --output-ext) OUTPUT_EXT="${2:-}"; shift 2 ;;

    --) shift; break ;;
    -*) die 11 "Unknown option: $1. $USAGE_SHORT" ;;
    *) POSITIONALS+=("$1"); shift ;;
  esac
done

if (( PRINT_EFFCONF )); then
  cat <<EOF
Effective config (post config-files + CLI):
  CRF_VALUE=$CRF_VALUE
  PRESET_VALUE=$PRESET_VALUE
  X265_PARAMS_BASE=$X265_PARAMS_BASE
  LEVEL_VALUE=$LEVEL_VALUE
  CONSERVATIVE_VBV=$CONSERVATIVE_VBV
  FORCE_CHROMA_420=$FORCE_CHROMA_420
  SDR_USE_10BIT_IF_SRC_10BIT=$SDR_USE_10BIT_IF_SRC_10BIT
  HDR_TARGET_PIXFMT=$HDR_TARGET_PIXFMT
  DISABLE_DV=$DISABLE_DV
  ALLOW_DV_FALLBACK=$ALLOW_DV_FALLBACK
  DV_CONVERT_TO_P81_IF_FAIL=$DV_CONVERT_TO_P81_IF_FAIL
  AUDIO_LANG_PREF=$AUDIO_LANG_PREF
  AUDIO_TRACK_OVERRIDE=${AUDIO_TRACK_OVERRIDE:-}
  ADD_STEREO_IF_MULTICH=$ADD_STEREO_IF_MULTICH
  STEREO_BITRATE=$STEREO_BITRATE
  SUB_LANG_PREF=$SUB_LANG_PREF
  SUB_INCLUDE_FORCED=$SUB_INCLUDE_FORCED
  SUB_INCLUDE_FULL=$SUB_INCLUDE_FULL
  SUB_INCLUDE_SDH=$SUB_INCLUDE_SDH
  SUB_ENABLE_OCR=$SUB_ENABLE_OCR
  SUB_OCR_TOOL=$SUB_OCR_TOOL
  SUB_OCR_LANG=$SUB_OCR_LANG
  OUTPUT_EXT=$OUTPUT_EXT
  DRY_RUN=$DRY_RUN
  CHECKSUM=$CHECKSUM
  KEEP_TEMP=$KEEP_TEMP
  KEEP_TEMP_ALWAYS=$KEEP_TEMP_ALWAYS
EOF
  exit 0
fi

# ===== Section 8: Required tools ===============================================================
need ffmpeg
need ffprobe
need dovi_tool

if (( SUB_ENABLE_OCR )); then
  if ! command -v "$SUB_OCR_TOOL" >/dev/null 2>&1; then
    warn "SUB_ENABLE_OCR=1 but '${SUB_OCR_TOOL}' not found in PATH — PGS OCR will be skipped."
    SUB_ENABLE_OCR=0
  fi
fi

# ===== Section 9: Input validation & security checks ===========================================
SRC="${POSITIONALS[0]:-}"
OUT="${POSITIONALS[1]:-}"
(( ${#POSITIONALS[@]} > 2 )) && die 11 "Too many arguments. $USAGE_SHORT"
[[ -z "$SRC" ]] && { print_usage; exit 0; }

# Validate output extension (security: prevent command injection)
case "$OUTPUT_EXT" in
  mp4|m4v|mov) ;;
  *) die 11 "Invalid OUTPUT_EXT: must be mp4, m4v, or mov (got: $OUTPUT_EXT)" ;;
esac

# Resolve and validate source file
SRC_ABS="$(realpath_fallback "$SRC")"
[[ -f "$SRC_ABS" ]] || die 11 "Source file not found: $SRC_ABS"
[[ -s "$SRC_ABS" ]] || die 11 "Source file is empty: $SRC_ABS"
[[ -r "$SRC_ABS" ]] || die 11 "Source file not readable: $SRC_ABS"

# Validate filename doesn't contain control characters (security)
if [[ "$SRC_ABS" =~ [[:cntrl:]] ]]; then
  die 11 "Source filename contains control characters - potential security risk"
fi

# Determine output path
if [[ -z "${OUT:-}" ]]; then
  base="${SRC_ABS%.*}"
  OUT="${base}.${OUTPUT_EXT}"
fi

# Resolve output directory and validate
OUT_DIR="$(dirname -- "$OUT")"
OUT_DIR="$(cd -- "$OUT_DIR" 2>/dev/null && pwd || echo "$OUT_DIR")"
[[ -d "$OUT_DIR" ]] || die 11 "Output directory does not exist: $OUT_DIR"
[[ -w "$OUT_DIR" ]] || die 11 "Output directory not writable: $OUT_DIR"

OUT_BASENAME="$(basename -- "$OUT")"
OUT_ABS="${OUT_DIR}/${OUT_BASENAME}"
OUT="$OUT_ABS"

# Validate output doesn't contain control characters (security)
if [[ "$OUT_ABS" =~ [[:cntrl:]] ]]; then
  die 11 "Output filename contains control characters - potential security risk"
fi

# Prevent overwriting source file (security/safety)
if [[ "$SRC_ABS" -ef "$OUT_ABS" ]]; then
  die 11 "Source and output are the same file - aborting to prevent data loss"
fi

# Security: Use unpredictable temp file name
TMP_OUT="$(mktemp "$OUT_DIR/.muxm.output.XXXXXXXX")" || die 11 "Cannot create temp output file"
rm -f "$TMP_OUT"  # Remove the file, we just wanted the name
TMP_OUT="${TMP_OUT}.${OUTPUT_EXT}"

# Determine mux format
MUX_FORMAT="mp4"
case "$OUTPUT_EXT" in
  mp4|m4v) MUX_FORMAT="mp4" ;;
  mov)     MUX_FORMAT="mov" ;;
esac

# ===== Section 10: Build ffmpeg/ffprobe flags ==================================================
FFMPEG_FLAGS=()
FFPROBE_FLAGS=()

(( FFMPEG_HIDE_BANNER )) && FFMPEG_FLAGS+=(-hide_banner)
FFMPEG_FLAGS+=(-loglevel "$FFMPEG_LOGLEVEL")
(( FFMPEG_OVERWRITE )) && FFMPEG_FLAGS+=(-y)

FFPROBE_FLAGS=(-v "$FFPROBE_LOGLEVEL")

PROBE_OPTS=(-analyzeduration 100M -probesize 100M)
FFMPEG_FLAGS+=("${PROBE_OPTS[@]}")
FFPROBE_FLAGS+=("${PROBE_OPTS[@]}")

# ===== Section 11: Workdir =====================================================================
WORKDIR="$(
  TMPDIR="$OUT_DIR" mktemp -d ".muxm.tmp.XXXXXXXX"
)" || die 11 "Cannot create working directory under: $OUT_DIR"
LOGFILE="$WORKDIR/muxm.$(date +%Y%m%d-%H%M%S).log"

# ===== Section 12: Begin logging to file =======================================================
if [[ "${DEBUG:-0}" != "1" ]]; then
  : > "$LOGFILE" 2>/dev/null || true
  exec > >(tee -a "$LOGFILE") 2>&1
  note "Logging to $(realpath_fallback "$LOGFILE")"
fi

# ===== Section 13: Traps =======================================================================
trap 'on_error $LINENO "$BASH_COMMAND" "$?"' ERR
trap 'FAILED=1; EXIT_CODE=130; FAIL_MSG="Interrupted by user (SIGINT)"; exit 130' INT
trap 'FAILED=1; EXIT_CODE=143; FAIL_MSG="Terminated (SIGTERM)"; exit 143' TERM

on_exit() {
  local have_result=0
  
  if (( DRY_RUN )); then
    have_result=1
  elif [[ -n "${TMP_OUT:-}" && -s "$TMP_OUT" ]]; then
    have_result=1
  elif [[ -n "${OUT:-}" && -s "$OUT" ]]; then
    have_result=1
  fi

  if (( FAILED == 0 && have_result == 1 )); then
    if (( DRY_RUN )); then
      note "DRY-RUN complete — no real files were created."
    else
      [[ -f "$TMP_OUT" ]] && mv -f "$TMP_OUT" "$OUT"
      (( CHECKSUM )) && write_checksum "$OUT"
      note "Build SUCCEEDED."
    fi

    if [[ ${#COMPLETED_STEPS[@]} -gt 0 ]]; then
      echo "---- Completed steps ----"
      for s in "${COMPLETED_STEPS[@]}"; do echo "  • $s"; done
    fi

    if [[ -n "$WORKDIR" && -d "$WORKDIR" && "${DEBUG:-0}" != "1" && $KEEP_TEMP_ALWAYS -eq 0 ]]; then
      rm -rf "$WORKDIR"
    else
      note "Keeping workdir: $WORKDIR"
    fi
    exit 0
  else
    [[ -z "$FAIL_MSG" ]] && FAIL_MSG="No output produced (likely earlier parse/runtime error)."
    printf "❌ Build FAILED. %s\n" "$FAIL_MSG"
    
    if [[ ${#COMPLETED_STEPS[@]} -gt 0 ]]; then
      echo "---- Completed steps ----"
      for s in "${COMPLETED_STEPS[@]}"; do echo "  • $s"; done
    fi
    echo "See log: $LOGFILE"

    # Clean up temp output file on failure
    [[ -f "$TMP_OUT" ]] && rm -f "$TMP_OUT"

    if [[ -n "$WORKDIR" && -d "$WORKDIR" && "${DEBUG:-0}" != "1" && $KEEP_TEMP -eq 0 && $KEEP_TEMP_ALWAYS -eq 0 ]]; then
      note "Keeping failure artifacts at: $WORKDIR (use -k to suppress this, or -K to always keep)"
    else
      note "Keeping failure artifacts at: $WORKDIR"
    fi
    exit "${EXIT_CODE:-1}"
  fi
}
trap 'on_exit' EXIT

# ===== Section 14: Disk space preflight ========================================================
disk_free_warn() {
  local avail_kb
  # Use POSIX-compliant df -P for portability
  avail_kb="$(df -Pk "$OUT_DIR" 2>/dev/null | awk 'NR==2{print $4}')"
  if [[ -n "$avail_kb" ]] && (( avail_kb < DISK_FREE_WARN_GB*1024*1024 )); then
    warn "Less than ~${DISK_FREE_WARN_GB}GB free on output volume ($OUT_DIR). Encode may fail."
  fi
}
disk_free_warn

# ===== Section 15: Metadata caching & ffprobe helpers ==========================================
# Cache all stream metadata in one call for performance
cache_stream_metadata() {
  note "→ Caching stream metadata..."
  METADATA_CACHE="$(ffprobe "${FFPROBE_FLAGS[@]}" -show_streams -of json "$SRC_ABS" 2>/dev/null)" || {
    die 12 "Failed to probe source file metadata - file may be corrupt"
  }
}

# Generic probe helper - reduces code duplication
_probe_stream_from_cache() {
  local stream_type="$1" idx="$2" field="$3"
  local jq_query=".streams[] | select(.codec_type==\"${stream_type}\") | select(.index==(${idx} + ([.streams[] | select(.codec_type==\"${stream_type}\")] | to_entries[${idx}].value.index // ${idx}))) | .${field} // empty"
  
  printf '%s\n' "$METADATA_CACHE" | jq -r "$jq_query" 2>/dev/null | head -n1 || true
}

_probe_field(){
  ffprobe "${FFPROBE_FLAGS[@]}" -show_entries "stream=$1" \
          -of default=nk=1:nw=1 "$2" 2>/dev/null | head -n1 || true
}

_has_stream(){
  printf '%s\n' "$METADATA_CACHE" | jq -e "[.streams[] | select(.codec_type==\"$2\")] | length > 0" >/dev/null 2>&1
}

# ===== Section 16: Color space & pixel format decision =========================================
declare -i IS_DV=0
PROFILE_DESC="SDR"
TARGET_PIXFMT="yuv420p"
COLOR_ARGS=()

decide_color_and_pixfmt() {
  local src="$1" pix prim trc cspace
  pix="$(_probe_field pix_fmt "$src")"
  prim="$(_probe_field color_primaries "$src")"
  trc="$(_probe_field color_transfer "$src")"
  cspace="$(_probe_field color_space "$src")"

  prim="$(printf %s "$prim"    | tr '[:upper:]' '[:lower:]')"
  trc="$(printf %s "$trc"      | tr '[:upper:]' '[:lower:]')"
  cspace="$(printf %s "$cspace"| tr '[:upper:]' '[:lower:]')"
  pix="$(printf %s "$pix"      | tr '[:upper:]' '[:lower:]')"

  local is_10bit=0 chroma="420"
  [[ "$pix" =~ p10 ]] && is_10bit=1
  [[ "$pix" =~ 422 ]] && chroma="422"
  [[ "$pix" =~ 444 ]] && chroma="444"

  if (( FORCE_CHROMA_420 )) && [[ "$chroma" != "420" ]]; then
    warn "Source chroma is 4:${chroma}; downsampling to 4:2:0 for Apple TV Direct Play."
    chroma="420"
  fi

  # Color Space Decision Tree:
  # ┌─ HLG (arib-std-b67) → HDR profile, bt2020
  # ├─ HDR10 (bt2020/smpte2084) → HDR10 profile, bt2020
  # └─ SDR (other) → SDR profile, 10-bit if source is 10-bit
  
  local tgt_pix="yuv420p" profile="SDR"
  if [[ "$trc" == "arib-std-b67" || "$trc" == "hlg" ]]; then
    profile="HLG"
    tgt_pix="$HDR_TARGET_PIXFMT"
    COLOR_ARGS=(-color_primaries bt2020 -color_trc arib-std-b67 -colorspace bt2020nc)
  elif [[ "$prim" == "bt2020" || "$cspace" == "bt2020nc" || "$trc" == "smpte2084" ]]; then
    profile="HDR10"
    tgt_pix="$HDR_TARGET_PIXFMT"
    COLOR_ARGS=(-color_primaries bt2020 -color_trc smpte2084 -colorspace bt2020nc)
  else
    profile="SDR"
    if (( SDR_USE_10BIT_IF_SRC_10BIT )) && (( is_10bit )); then
      tgt_pix="yuv420p10le"
    else
      tgt_pix="yuv420p"
    fi
    [[ -z "$prim" ]] && prim="bt709"
    [[ -z "$trc" ]] && trc="bt709"
    [[ -z "$cspace" ]] && cspace="bt709"
    COLOR_ARGS=(-color_primaries "$prim" -color_trc "$trc" -colorspace "$cspace")
  fi
  PROFILE_DESC="$profile"
  TARGET_PIXFMT="$tgt_pix"
  
  note "Color profile: $PROFILE_DESC, Target pixel format: $TARGET_PIXFMT"
}

# ===== Section 17: x265 params & Level/VBV guardrails =========================================
build_x265_params() {
  X265_PARAMS="$X265_PARAMS_BASE"

  # Remove hdr-opt if not HDR10
  if [[ "$PROFILE_DESC" != "HDR10" ]]; then
    X265_PARAMS="${X265_PARAMS/:hdr-opt=1/}"
  fi

  # Add HDR10-specific params if HDR10
  if [[ "$PROFILE_DESC" == "HDR10" ]]; then
    X265_PARAMS="${X265_PARAMS}:hdr10=1:hdr10-opt=1:colorprim=bt2020:transfer=smpte2084:colormatrix=bt2020nc:range=limited"
  fi
}

# Apply level-based VBV constraints
# VBV (Video Buffering Verifier) ensures bitrate stays within device capabilities
apply_level_vbv() {
  local lvl="$1" maxrate="" bufsize=""
  if (( CONSERVATIVE_VBV )); then
    case "$lvl" in
      4.1) maxrate="$LEVEL_VBV_4_1_MAXRATE"; bufsize="$LEVEL_VBV_4_1_BUFSIZE" ;;
      5.0) maxrate="$LEVEL_VBV_5_0_MAXRATE"; bufsize="$LEVEL_VBV_5_0_BUFSIZE" ;;
      5.1) maxrate="$LEVEL_VBV_5_1_MAXRATE"; bufsize="$LEVEL_VBV_5_1_BUFSIZE" ;;
      5.2) maxrate="$LEVEL_VBV_5_2_MAXRATE"; bufsize="$LEVEL_VBV_5_2_BUFSIZE" ;;
    esac
  fi
  if [[ -n "$maxrate" ]]; then
    X265_PARAMS="${X265_PARAMS}:level-idc=${lvl}:vbv-maxrate=${maxrate}:vbv-bufsize=${bufsize}"
    note "Applying VBV guardrails for level ${lvl} → maxrate=${maxrate}, bufsize=${bufsize}"
  else
    [[ -n "$lvl" ]] && X265_PARAMS="${X265_PARAMS}:level-idc=${lvl}"
  fi
}

# ===== Section 18: Dolby Vision detection ======================================================
detect_dv() {
  (( DISABLE_DV )) && return 1
  
  local probe_output
  probe_output="$(ffprobe "${FFPROBE_FLAGS[@]}" -show_streams -select_streams v:0 "$SRC_ABS" 2>&1)" || {
    warn "ffprobe failed during DV detection - assuming no DV present"
    return 1
  }
  
  if printf '%s\n' "$probe_output" | grep -m1 -qiE 'dolby_vision|dv_profile|dovi|dvhe|dvh1|com\.dolby\.vision'; then
    return 0
  fi
  
  # Check first few frames for DV metadata
  probe_output="$(ffprobe "${FFPROBE_FLAGS[@]}" -show_frames -read_intervals %+#5 -select_streams v:0 "$SRC_ABS" 2>&1)" || {
    warn "Frame analysis failed during DV detection - assuming no DV"
    return 1
  }
  
  printf '%s\n' "$probe_output" | grep -m1 -qiE 'DOVI|dolby' && return 0
  return 1
}

# ===== Section 19: Temp paths ==================================================================
V_SRC_ES="$WORKDIR/video_src.es"
RPU_P7="$WORKDIR/rpu_p7.bin"
RPU_P81="$WORKDIR/rpu_p81.bin"
V_BASE="$WORKDIR/video_base.hevc"
V_MIXED="$WORKDIR/video_mixed.hevc"

A_PRIMARY=""
AAC_STEREO=""
declare -i HAS_AUDIO=0

# ===== Section 20: Video pipeline ==============================================================
run_video_pipeline() {
  note "→ Preparing raw video elementary stream…"
  
  if (( DRY_RUN )); then
    : > "$V_SRC_ES" 2>/dev/null || true
    mark_done "Demux raw ES → video_src.es (dry-run)"
  else
    # Extract HEVC elementary stream for DV RPU extraction
    # Use -c copy; if it fails we still proceed (DV path will fallback)
    if ! ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:v:0 -c copy -f hevc "$V_SRC_ES" 2>"$WORKDIR/demux.err"; then
      local codec
      codec="$(_probe_field codec_name "$SRC_ABS")"
      warn "Could not demux raw ES - source codec: ${codec:-unknown}. DV extraction may be skipped."
      warn "See: $WORKDIR/demux.err for details"
      : > "$V_SRC_ES" 2>/dev/null || true
    fi
    mark_done "Demux raw ES → video_src.es"
  fi

  note "→ Encoding base video (${PROFILE_DESC}, ${TARGET_PIXFMT}, preset ${PRESET_VALUE}, CRF ${CRF_VALUE}) → $V_BASE"
  
  if (( DRY_RUN )); then
    : > "$V_BASE" 2>/dev/null || true
    mark_done "Encode base video (dry-run)"
  else
    local thread_args=()
    [[ -n "${THREADS:-}" ]] && thread_args=(-threads "$THREADS")

    # Encode base HEVC video with color space preservation
    if ! ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:v:0 \
      -pix_fmt "$TARGET_PIXFMT" \
      "${COLOR_ARGS[@]}" \
      -c:v libx265 -preset "$PRESET_VALUE" -crf "$CRF_VALUE" \
      "${thread_args[@]}" \
      -x265-params "$X265_PARAMS" \
      -an -sn -dn \
      -f hevc "$V_BASE" 2>"$WORKDIR/encode.err"; then
      die 40 "Base video encode failed. See: $WORKDIR/encode.err"
    fi

    # Validate encoded output
    if [[ ! -s "$V_BASE" ]]; then
      die 40 "Base video encode produced empty file"
    fi
    
    if ! ffprobe -v error "$V_BASE" >/dev/null 2>&1; then
      die 40 "Base video encode produced corrupt file"
    fi

    mark_done "Encode base video"
  fi

  note "→ Finalizing video stream (DV inject if available) → $V_MIXED"

  if (( DRY_RUN )); then
    : > "$V_MIXED" 2>/dev/null || true
    mark_done "Use base video (dry-run)"
    return 0
  fi

  # Default: no DV, or DV disabled → use base
  if (( IS_DV == 0 || DISABLE_DV == 1 )); then
    cp -f "$V_BASE" "$V_MIXED"
    mark_done "Use base video (non-DV)"
    return 0
  fi

  # Try extracting RPU from the demuxed ES
  if [[ ! -s "$V_SRC_ES" ]]; then
    warn "No ES available for DV extraction; using base video."
    cp -f "$V_BASE" "$V_MIXED"
    mark_done "Use base video (non-DV fallback - no ES)"
    return 0
  fi

  if ! dovi_tool extract-rpu -i "$V_SRC_ES" -o "$RPU_P7" >/dev/null 2>&1; then
    warn "DV RPU extract failed; using base video."
    if (( ALLOW_DV_FALLBACK )); then
      cp -f "$V_BASE" "$V_MIXED"
      mark_done "Use base video (DV extract failed)"
      return 0
    fi
    die 40 "Dolby Vision RPU extraction failed and fallback is disabled"
  fi

  # Optional: convert DV profile if requested
  if (( DV_CONVERT_TO_P81_IF_FAIL )); then
    if dovi_tool convert --rpu-in "$RPU_P7" --rpu-out "$RPU_P81" >/dev/null 2>&1; then
      note "DV profile converted (P7 → P8.1)"
    else
      # Conversion failed, use original RPU
      cp -f "$RPU_P7" "$RPU_P81" 2>/dev/null || true
    fi
  else
    cp -f "$RPU_P7" "$RPU_P81" 2>/dev/null || true
  fi

  # Inject RPU into encoded video
  if ! dovi_tool inject-rpu -i "$V_BASE" --rpu-in "$RPU_P81" -o "$V_MIXED" >/dev/null 2>&1; then
    warn "DV RPU injection failed; using base video."
    if (( ALLOW_DV_FALLBACK )); then
      cp -f "$V_BASE" "$V_MIXED"
      mark_done "Use base video (DV inject failed)"
      return 0
    fi
    die 41 "Dolby Vision RPU injection failed and fallback is disabled"
  fi

  # Validate DV-injected output
  if [[ ! -s "$V_MIXED" ]]; then
    warn "DV injection produced empty file; using base video."
    cp -f "$V_BASE" "$V_MIXED"
    mark_done "Use base video (DV inject empty)"
    return 0
  fi

  mark_done "DV inject (best-effort)"
}

# ===== Section 21: Audio selection & pipeline ==================================================
# Count audio streams in source file
# Returns: Integer count (0 if none)
# Globals: METADATA_CACHE
_audio_stream_count(){
  printf '%s\n' "$METADATA_CACHE" | jq '[.streams[] | select(.codec_type=="audio")] | length' 2>/dev/null || echo 0
}

# Get audio field from cached metadata
# Args: stream_index field_name
_audio_field(){
  local idx="$1" field="$2" stream_idx
  stream_idx=$(printf '%s\n' "$METADATA_CACHE" | jq "[.streams[] | select(.codec_type==\"audio\")] | .[$idx].index" 2>/dev/null)
  printf '%s\n' "$METADATA_CACHE" | jq -r ".streams[] | select(.index==$stream_idx) | .$field // empty" 2>/dev/null | head -n1 || true
}

# Get audio tag from cached metadata
_audio_tag(){
  local idx="$1" tag="$2" stream_idx
  stream_idx=$(printf '%s\n' "$METADATA_CACHE" | jq "[.streams[] | select(.codec_type==\"audio\")] | .[$idx].index" 2>/dev/null)
  printf '%s\n' "$METADATA_CACHE" | jq -r ".streams[] | select(.index==$stream_idx) | .tags.$tag // empty" 2>/dev/null | head -n1 || true
}

_audio_lang(){
  local lang
  lang="$(_audio_tag "$1" language | tr '[:upper:]' '[:lower:]')"
  [[ -z "$lang" ]] && lang="$TAG_LANGUAGE_DEFAULT"
  echo "$lang"
}

_audio_channels(){
  local ch
  ch="$(_audio_field "$1" channels)"
  [[ -z "$ch" ]] && ch=0
  echo "$ch"
}

_audio_bitrate(){
  local br
  br="$(_audio_field "$1" bit_rate)"
  [[ -z "$br" ]] && br=0
  echo "$br"
}

_audio_codec(){
  local c
  c="$(_audio_field "$1" codec_name | tr '[:upper:]' '[:lower:]')"
  [[ -z "$c" ]] && c="unknown"
  echo "$c"
}

_audio_title(){
  _audio_tag "$1" title
}

# Calculate codec preference rank (lower is better)
_audio_codec_rank(){
  local codec="$1" list="$AUDIO_CODEC_PREFERENCE" item i=0
  IFS=',' read -r -a arr <<<"$list"
  for item in "${arr[@]}"; do
    item="$(printf '%s' "$item" | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')"
    [[ -z "$item" ]] && continue
    if [[ "$item" == "$codec" ]]; then echo "$i"; return 0; fi
    (( i++, 1 ))
  done
  echo "99"
}

# Score audio stream for selection
# Returns: score|idx|codec|channels|lang|title
_score_audio_stream(){
  local idx="$1"
  local codec lang ch br rank score title
  codec="$(_audio_codec "$idx")"
  lang="$(_audio_lang "$idx")"
  ch="$(_audio_channels "$idx")"
  br="$(_audio_bitrate "$idx")"
  rank="$(_audio_codec_rank "$codec")"
  title="$(_audio_title "$idx")"

  score=0
  # Channel count matters most
  score=$(( score + ch * AUDIO_SCORE_CHANNEL_MULTIPLIER ))
  # Surround bonus (>=6ch)
  (( ch >= 6 )) && score=$(( score + AUDIO_SCORE_SURROUND_BONUS ))
  # Language bonus for preferred language
  if [[ "$lang" == "eng" ]]; then
    score=$(( score + AUDIO_SCORE_LANG_BONUS_ENG ))
  fi
  # Codec preference: better rank -> higher score
  local inv=$(( 120 - rank ))
  (( inv < 0 )) && inv=0
  score=$(( score + inv ))

  # Bitrate small tie-breaker (scaled)
  if [[ "$br" =~ ^[0-9]+$ ]] && (( br > 0 )); then
    score=$(( score + (br / 50000) ))
  fi

  printf "%s|%s|%s|%s|%s|%s\n" "$score" "$idx" "$codec" "$ch" "$lang" "${title:-}"
}

# Select best audio track based on scoring algorithm
select_best_audio(){
  local n i best_line best_score=-999999
  n="$(_audio_stream_count)"
  (( n > 0 )) || { echo ""; return 0; }

  # Handle user override with validation
  if [[ -n "${AUDIO_TRACK_OVERRIDE:-}" ]]; then
    if [[ "$AUDIO_TRACK_OVERRIDE" =~ ^[0-9]+$ ]] && (( AUDIO_TRACK_OVERRIDE >= 0 && AUDIO_TRACK_OVERRIDE < n )); then
      echo "$AUDIO_TRACK_OVERRIDE"
      return 0
    fi
    warn "Requested --audio-track $AUDIO_TRACK_OVERRIDE is invalid (must be 0-$((n-1))). Using auto-selection."
  fi

  # Score all tracks and select best
  for (( i=0; i<n; i++ )); do
    local line score
    line="$(_score_audio_stream "$i")"
    score="${line%%|*}"
    if [[ "$score" =~ ^-?[0-9]+$ ]] && (( score > best_score )); then
      best_score="$score"
      best_line="$line"
    fi
  done

  # Extract index from best_line (format: score|idx|codec|ch|lang|title)
  echo "${best_line#*|}" | cut -d'|' -f1
}

# Check if audio codec can be direct-play copied to MP4
audio_is_direct_play_copyable(){
  local codec="$1"
  case "$codec" in
    aac|alac|ac3|eac3) return 0 ;;
    *) return 1 ;;
  esac
}

# Determine target codec for audio transcode based on channel count
audio_target_codec_for_transcode(){
  local ch="$1"
  if (( ch >= 6 )); then
    echo "eac3"
  else
    echo "aac"
  fi
}

# Determine target bitrate based on channel count
audio_target_bitrate(){
  local ch="$1"
  if (( ch >= 8 )); then echo "$EAC3_BITRATE_7_1"; return 0; fi
  if (( ch >= 6 )); then echo "$EAC3_BITRATE_5_1"; return 0; fi
  echo "192k"
}

run_audio_pipeline(){
  local n best idx codec ch lang br title
  n="$(_audio_stream_count)"
  
  if (( n == 0 )); then
    note "No audio streams detected."
    HAS_AUDIO=0
    return 0
  fi

  idx="$(select_best_audio)"
  [[ -n "$idx" ]] || { HAS_AUDIO=0; return 0; }

  codec="$(_audio_codec "$idx")"
  ch="$(_audio_channels "$idx")"
  lang="$(_audio_lang "$idx")"
  br="$(_audio_bitrate "$idx")"
  title="$(_audio_title "$idx")"

  say "• Detected audio streams:"
  local i
  for (( i=0; i<n; i++ )); do
    local c ch_i l t br_i pretty
    c="$(_audio_codec "$i")"
    ch_i="$(_audio_channels "$i")"
    l="$(_audio_lang "$i")"
    t="$(_audio_title "$i")"
    br_i="$(_audio_bitrate "$i")"
    
    pretty="#$i: $c ${ch_i}ch [$l]"
    [[ -n "$t" ]] && pretty="$pretty — $t"
    [[ "$br_i" =~ ^[0-9]+$ ]] && (( br_i > 0 )) && pretty="$pretty, $((br_i/1000))kbps"
    say "  $pretty"
  done

  note "[Audio Select] Using track #$idx: $codec ${ch}ch [$lang]${title:+ — $title}${br:+, $((br/1000))kbps}"

  A_PRIMARY="$WORKDIR/audio_primary.${codec}"
  AAC_STEREO="$WORKDIR/audio_stereo.ac3"
  HAS_AUDIO=1

  note "→ Preparing primary audio → $A_PRIMARY"

  if (( DRY_RUN )); then
    : > "$A_PRIMARY" 2>/dev/null || true
    mark_done "Primary audio prepared (dry-run)"
    if (( ADD_STEREO_IF_MULTICH )) && (( ch > 2 )); then
      : > "$AAC_STEREO" 2>/dev/null || true
      mark_done "Stereo fallback prepared (dry-run)"
    fi
    return 0
  fi

  # Copy or transcode primary audio
  if audio_is_direct_play_copyable "$codec"; then
    note "Direct Play audio codec detected ($codec). Copying without conversion."
    if ! ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:a:"$idx" -c copy "$A_PRIMARY" 2>"$WORKDIR/audio_primary.err"; then
      die 43 "Audio copy failed. See: $WORKDIR/audio_primary.err"
    fi
  else
    local tgt_codec tgt_br
    tgt_codec="$(audio_target_codec_for_transcode "$ch")"
    tgt_br="$(audio_target_bitrate "$ch")"
    note "Transcoding audio: $codec → $tgt_codec (channels=${ch}ch, bitrate=$tgt_br)"
    A_PRIMARY="$WORKDIR/audio_primary.${tgt_codec}"

    if [[ "$tgt_codec" == "eac3" ]]; then
      if ! ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:a:"$idx" \
        -c:a eac3 -b:a "$tgt_br" -ac "${ch}" "$A_PRIMARY" 2>"$WORKDIR/audio_primary.err"; then
        die 43 "E-AC3 audio transcode failed. See: $WORKDIR/audio_primary.err"
      fi
    else
      # AAC
      if ! ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:a:"$idx" \
        -c:a aac -b:a "$tgt_br" -ac "${ch}" "$A_PRIMARY" 2>"$WORKDIR/audio_primary.err"; then
        die 43 "AAC audio transcode failed. See: $WORKDIR/audio_primary.err"
      fi
    fi
  fi

  # Validate primary audio
  if [[ ! -s "$A_PRIMARY" ]]; then
    die 43 "Primary audio preparation produced empty file"
  fi

  mark_done "Primary audio prepared"

  # Add stereo fallback if needed
  if (( ADD_STEREO_IF_MULTICH )) && (( ch > 2 )); then
    note "→ Preparing stereo fallback → $AAC_STEREO"
    if ! ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:a:"$idx" \
      -c:a ac3 -b:a "$STEREO_BITRATE" -ac 2 "$AAC_STEREO" 2>"$WORKDIR/audio_stereo.err"; then
      warn "Stereo fallback creation failed - continuing without it. See: $WORKDIR/audio_stereo.err"
      AAC_STEREO=""
    else
      mark_done "Stereo fallback prepared"
    fi
  else
    note "Primary audio is stereo (or fallback disabled); no extra stereo needed."
  fi
}

# ===== Section 22: Subtitle helpers (planner + OCR) ===========================================
# Count subtitle streams in source file
_sub_count() {
  printf '%s\n' "$METADATA_CACHE" | jq '[.streams[] | select(.codec_type=="subtitle")] | length' 2>/dev/null || echo 0
}

# List all subtitle stream indices
list_sub_indices(){
  local n i
  n="$(_sub_count)"
  for (( i=0; i<n; i++ )); do echo "$i"; done
}

# Get subtitle field from cached metadata
_sp_sub_field() {
  local idx="$1" field="$2" stream_idx
  stream_idx=$(printf '%s\n' "$METADATA_CACHE" | jq "[.streams[] | select(.codec_type==\"subtitle\")] | .[$idx].index" 2>/dev/null)
  printf '%s\n' "$METADATA_CACHE" | jq -r ".streams[] | select(.index==$stream_idx) | .$field // empty" 2>/dev/null | head -n1 || true
}

# Get subtitle tag from cached metadata
_sp_sub_tag() {
  local idx="$1" tag="$2" stream_idx
  stream_idx=$(printf '%s\n' "$METADATA_CACHE" | jq "[.streams[] | select(.codec_type==\"subtitle\")] | .[$idx].index" 2>/dev/null)
  printf '%s\n' "$METADATA_CACHE" | jq -r ".streams[] | select(.index==$stream_idx) | .tags.$tag // empty" 2>/dev/null | head -n1 || true
}

# Check if subtitle stream has forced disposition
_sp_sub_dispo_forced(){
  local idx="$1" stream_idx
  stream_idx=$(printf '%s\n' "$METADATA_CACHE" | jq "[.streams[] | select(.codec_type==\"subtitle\")] | .[$idx].index" 2>/dev/null)
  printf '%s\n' "$METADATA_CACHE" | jq ".streams[] | select(.index==$stream_idx) | .disposition.forced // 0" 2>/dev/null | head -n1 || echo 0
}

_sp_sub_lang(){
  local lang
  lang="$(_sp_sub_tag "$1" language | tr '[:upper:]' '[:lower:]')"
  [[ -z "$lang" ]] && lang="$TAG_LANGUAGE_DEFAULT"
  echo "$lang"
}

_is_forced_title(){
  local t
  t="$(printf %s "$1" | tr '[:upper:]' '[:lower:]')"
  [[ "$t" =~ forced|signs|foreign ]]
}

_is_sdh_title(){
  local t
  t="$(printf %s "$1" | tr '[:upper:]' '[:lower:]')"
  [[ "$t" =~ (^|[^a-z])(sdh|hi)([^a-z]|$)|hearing|impaired|cc|caption ]]
}

# Describe subtitle stream for user
describe_sub_stream(){
  local i="$1" codec lang title forced flags=""
  codec="$(_sp_sub_field "$i" codec_name | tr '[:upper:]' '[:lower:]')"
  lang="$(_sp_sub_lang "$i")"
  title="$(_sp_sub_tag "$i" title)"
  forced="$(_sp_sub_dispo_forced "$i")"
  
  (( forced )) && flags=" (forced)"
  if _is_sdh_title "$title"; then
    [[ -n "$flags" ]] && flags="$flags, "
    flags="${flags}SDH"
  fi
  
  printf "#%s: %s [%s]%s%s\n" "$i" "${codec:-?}" "$lang" "${title:+ — $title}" "$flags"
}

_is_text_sub_codec(){
  local c="$1"
  case "$c" in
    subrip|srt|ass|ssa|webvtt|vtt|mov_text) return 0 ;;
    *) return 1 ;;
  esac
}

_pick_direct_text_sub_relidx(){
  local i lang codec
  for i in $(list_sub_indices); do
    lang="$(_sp_sub_lang "$i")"
    [[ ",$SUB_LANG_PREF," == *",$lang,"* ]] || continue
    codec="$(_sp_sub_field "$i" codec_name | tr '[:upper:]' '[:lower:]')"
    if _is_text_sub_codec "$codec"; then
      echo "$i"
      return 0
    fi
  done
  echo ""
}

# Prepare subtitle to SRT format (with OCR if needed)
# Args: subtitle_stream_index
# Returns: path to SRT file or empty string if failed
_prepare_sub_to_srt(){
  local idx="$1" codec srt sup vob_base
  codec="$(_sp_sub_field "$idx" codec_name | tr '[:upper:]' '[:lower:]')"
  srt="$WORKDIR/sub.${idx}.srt"

  if (( DRY_RUN )); then
    printf "1\n00:00:00,000 --> 00:00:00,500\n(dry-run)\n" >"$srt" 2>/dev/null || true
    echo "$srt"
    return 0
  fi

  case "$codec" in
    subrip|srt)
      if ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:s:"$idx" -c copy "$srt" 2>"$WORKDIR/sub_${idx}.err"; then
        echo "$srt"
        return 0
      fi
      warn "Failed to extract SRT subtitle #$idx. See: $WORKDIR/sub_${idx}.err"
      ;;
      
    ass|ssa|webvtt|vtt)
      if ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:s:"$idx" "$srt" 2>"$WORKDIR/sub_${idx}.err"; then
        echo "$srt"
        return 0
      fi
      warn "Failed to convert subtitle #$idx to SRT. See: $WORKDIR/sub_${idx}.err"
      ;;
      
    hdmv_pgs_subtitle|pgs)
      if (( ! SUB_ENABLE_OCR )); then
        warn "PGS subtitle #$idx requires OCR but OCR is disabled — skipping."
        echo ""
        return 0
      fi

      sup="$WORKDIR/sub.${idx}.sup"
      if ! ffmpeg "${FFMPEG_FLAGS[@]}" -i "$SRC_ABS" -map 0:s:"$idx" -c:s copy "$sup" 2>"$WORKDIR/sub_${idx}_extract.err"; then
        warn "Failed extracting PGS #$idx to .sup — skipping. See: $WORKDIR/sub_${idx}_extract.err"
        echo ""
        return 0
      fi

      # Try vobsub conversion if muxer is available
      if ffmpeg_has_muxer vobsub; then
        vob_base="$WORKDIR/sub.${idx}.vob"
        if ! ffmpeg "${FFMPEG_FLAGS[@]}" -i "$sup" -map 0:s:0 -c:s dvdsub -f vobsub "$vob_base" 2>"$WORKDIR/sub_${idx}_vobsub.err"; then
          warn "PGS→VobSub conversion failed for #$idx. See: $WORKDIR/sub_${idx}_vobsub.err"
          echo ""
          return 0
        fi

        # Run OCR tool
        if "$SUB_OCR_TOOL" "${vob_base}.idx" >/dev/null 2>&1 || "$SUB_OCR_TOOL" -l "$SUB_OCR_LANG" "${vob_base}.idx" >/dev/null 2>&1; then
          if [[ -s "${vob_base}.srt" ]]; then
            mv -f "${vob_base}.srt" "$srt" || true
          fi
          if [[ -s "$srt" ]]; then
            echo "$srt"
            return 0
          fi
        fi
        warn "OCR tool failed for subtitle #$idx — skipping."
        echo ""
        return 0
      fi

      # Fallback: try OCR tool directly on .sup
      if "$SUB_OCR_TOOL" "$sup" >/dev/null 2>&1 || "$SUB_OCR_TOOL" -l "$SUB_OCR_LANG" "$sup" >/dev/null 2>&1; then
        if [[ -s "${sup%.sup}.srt" ]]; then
          mv -f "${sup%.sup}.srt" "$srt" || true
        elif [[ -s "${sup}.srt" ]]; then
          mv -f "${sup}.srt" "$srt" || true
        fi
        if [[ -s "$srt" ]]; then
          echo "$srt"
          return 0
        fi
      fi

      warn "PGS OCR could not run (no vobsub muxer; tool didn't accept .sup) — skipping subtitle #$idx."
      echo ""
      return 0
      ;;
      
    *)
      warn "Unsupported subtitle codec '$codec' for #$idx — skipping."
      ;;
  esac

  echo ""
  return 0
}

SRT_FORCED=""
SRT_FULL=""
SRT_SDH=""
declare -i SRT_DIRECT_MAP=0
DIRECT_SUB_RELIDX=""

# Build subtitle processing plan
build_subtitle_plan(){
  if (( SKIP_SUBS )); then
    SRT_FORCED=""; SRT_FULL=""; SRT_SDH=""
    SRT_DIRECT_MAP=0; DIRECT_SUB_RELIDX=""
    return 0
  fi

  if ! _has_stream "$SRC_ABS" subtitle; then
    note "[Subs] No subtitle streams detected."
    SRT_DIRECT_MAP=0
    return 0
  fi

  say "→ Scanning subtitle streams:"
  local i
  for i in $(list_sub_indices); do
    describe_sub_stream "$i" || true
  done

  local forced_idx="" full_idx="" sdh_idx=""
  local lang title forced is_sdh

  # Find best subtitle candidates
  for i in $(list_sub_indices); do
    lang="$(_sp_sub_lang "$i")"
    [[ ",$SUB_LANG_PREF," == *",$lang,"* ]] || continue

    title="$(_sp_sub_tag "$i" title)"
    forced="$(_sp_sub_dispo_forced "$i")"
    if _is_sdh_title "$title"; then is_sdh=1; else is_sdh=0; fi

    # Categorize subtitle
    if (( SUB_INCLUDE_FORCED )) && { (( forced )) || _is_forced_title "$title"; }; then
      [[ -z "$forced_idx" ]] && forced_idx="$i"
      continue
    fi

    if (( SUB_INCLUDE_SDH )) && (( is_sdh == 1 )); then
      [[ -z "$sdh_idx" ]] && sdh_idx="$i"
      continue
    fi

    if (( SUB_INCLUDE_FULL )) && (( is_sdh == 0 )); then
      [[ -z "$full_idx" ]] && full_idx="$i"
      continue
    fi
  done

  # Prepare selected subtitles (up to SUB_MAX_TRACKS)
  local p pick_count=0
  if [[ -n "$forced_idx" ]]; then
    p="$(_prepare_sub_to_srt "$forced_idx")"
    [[ -n "$p" ]] && SRT_FORCED="$p" && (( pick_count++, 1 )) && note "[Subs] Prepared Forced → $SRT_FORCED"
  fi
  if [[ -n "$full_idx" && $pick_count -lt $SUB_MAX_TRACKS ]]; then
    p="$(_prepare_sub_to_srt "$full_idx")"
    [[ -n "$p" ]] && SRT_FULL="$p" && (( pick_count++, 1 )) && note "[Subs] Prepared Full → $SRT_FULL"
  fi
  if [[ -n "$sdh_idx" && $pick_count -lt $SUB_MAX_TRACKS ]]; then
    p="$(_prepare_sub_to_srt "$sdh_idx")"
    [[ -n "$p" ]] && SRT_SDH="$p" && (( pick_count++, 1 )) && note "[Subs] Prepared SDH → $SRT_SDH"
  fi

  # Fallback: try direct-mapping a text subtitle if no SRTs prepared
  if [[ -z "$SRT_FORCED" && -z "$SRT_FULL" && -z "$SRT_SDH" ]]; then
    DIRECT_SUB_RELIDX="$(_pick_direct_text_sub_relidx)"
    if [[ -n "$DIRECT_SUB_RELIDX" ]]; then
      SRT_DIRECT_MAP=1
      note "[Subs] No external SRTs prepared — enabling direct-map of TEXT subtitle stream #$DIRECT_SUB_RELIDX."
    else
      SRT_DIRECT_MAP=0
      note "[Subs] No usable subtitles prepared. Proceeding without subtitles."
    fi
  fi
}

# ===== Section 23: Final mux ===================================================================
mux_final() {
  say "→ Muxing final ${OUTPUT_EXT^^} with ffmpeg → $TMP_OUT"

  if (( DRY_RUN )); then
    : > "$TMP_OUT" 2>/dev/null || true
    mark_done "Mux final (dry-run)"
    return 0
  fi

  local -a ff_in=()
  local -a ff_map=()
  local -a ff_codec=()

  ff_in+=( "${FFMPEG_FLAGS[@]}" )

  local next_idx=0
  local vid_idx="" a_primary_idx="" a_stereo_idx=""
  local s_forced_idx="" s_full_idx="" s_sdh_idx=""
  local forced_present=0 full_present=0 sdh_present=0
  local src_sub_idx=""

  # Validate and add video stream
  if (( SKIP_VIDEO )); then
    die 42 "Video was skipped but output container requires a video stream."
  fi
  
  if [[ -n "${V_MIXED:-}" && -s "$V_MIXED" ]]; then
    # Validate video before muxing
    if ! ffprobe -v error "$V_MIXED" >/dev/null 2>&1; then
      die 42 "Encoded video exists but is invalid/corrupt"
    fi
    ff_in+=( -i "$V_MIXED" )
    vid_idx=$next_idx
    (( next_idx++, 1 ))
  else
    die 42 "No encoded video stream found."
  fi

  # Add audio streams
  if (( ! SKIP_AUDIO )) && (( HAS_AUDIO )) && [[ -n "${A_PRIMARY:-}" && -s "$A_PRIMARY" ]]; then
    ff_in+=( -i "$A_PRIMARY" )
    a_primary_idx=$next_idx
    (( next_idx++, 1 ))
  fi
  
  if (( ! SKIP_AUDIO )) && [[ -n "${AAC_STEREO:-}" && -s "$AAC_STEREO" ]]; then
    ff_in+=( -i "$AAC_STEREO" )
    a_stereo_idx=$next_idx
    (( next_idx++, 1 ))
  fi

  # Add subtitle streams
  if (( ! SKIP_SUBS )); then
    if [[ -n "${SRT_FORCED:-}" && -s "$SRT_FORCED" ]]; then
      ff_in+=( -i "$SRT_FORCED" )
      s_forced_idx=$next_idx
      (( next_idx++, 1 ))
      forced_present=1
    fi
    
    if [[ -n "${SRT_FULL:-}" && -s "$SRT_FULL" ]]; then
      ff_in+=( -i "$SRT_FULL" )
      s_full_idx=$next_idx
      (( next_idx++, 1 ))
      full_present=1
    fi
    
    if [[ -n "${SRT_SDH:-}" && -s "$SRT_SDH" ]]; then
      ff_in+=( -i "$SRT_SDH" )
      s_sdh_idx=$next_idx
      (( next_idx++, 1 ))
      sdh_present=1
    fi
  fi

  # Add source for direct subtitle mapping if needed
  if (( ! SKIP_SUBS )) && (( SRT_DIRECT_MAP )) && [[ -n "${DIRECT_SUB_RELIDX:-}" ]]; then
    ff_in+=( -i "$SRC_ABS" )
    src_sub_idx=$next_idx
    (( next_idx++, 1 ))
  fi

  # Build stream mapping
  ff_map+=( -map "$vid_idx":v:0 )

  [[ -n "$a_primary_idx" ]] && ff_map+=( -map "$a_primary_idx":a:0 )
  [[ -n "$a_stereo_idx"  ]] && ff_map+=( -map "$a_stereo_idx":a:0 )

  (( forced_present )) && ff_map+=( -map "$s_forced_idx":s:0 )
  (( full_present   )) && ff_map+=( -map "$s_full_idx":s:0 )
  (( sdh_present    )) && ff_map+=( -map "$s_sdh_idx":s:0 )

  if [[ -n "$src_sub_idx" ]]; then
    ff_map+=( -map "$src_sub_idx":s:"$DIRECT_SUB_RELIDX"? )
  fi

  # Codec settings: copy everything, convert subs to mov_text
  ff_codec+=( -c copy )

  if (( forced_present || full_present || sdh_present )) || [[ -n "$src_sub_idx" ]]; then
    ff_codec+=( -c:s mov_text )
  fi

  # MP4 optimization
  ff_codec+=( -movflags +faststart )

  # Execute final mux
  if ! ffmpeg "${ff_in[@]}" "${ff_map[@]}" "${ff_codec[@]}" -f "$MUX_FORMAT" "$TMP_OUT" 2>"$WORKDIR/mux.err"; then
    die 41 "ffmpeg final mux failed. See: $WORKDIR/mux.err"
  fi

  # Validate muxed output
  if [[ ! -s "$TMP_OUT" ]]; then
    die 41 "Final mux produced empty file"
  fi
  
  if ! ffprobe -v error "$TMP_OUT" >/dev/null 2>&1; then
    die 41 "Final mux produced corrupt file"
  fi

  mark_done "Mux final ${OUTPUT_EXT}"
}

# ===== Section 24: Main =========================================================================
main() {
  say "=== ${APP_NAME} v${VERSION} — CLI: ${CLI_NAME}"
  say "=== Input      : $SRC_ABS"
  say "=== Output     : $OUT"
  say "=== Workdir    : $WORKDIR"
  say "=== Defaults   : CRF=$CRF_VALUE  StereoBitrate=$STEREO_BITRATE  Preset=$PRESET_VALUE"

  (( DRY_RUN )) && note "DRY-RUN is ON"
  [[ ${#MUXM_CONFIG_LOADED[@]} -gt 0 ]] && note "Loaded config: ${MUXM_CONFIG_LOADED[*]}"
  (( SKIP_VIDEO )) && note "[Quick Test] Video processing disabled (--skip-video)"
  (( SKIP_AUDIO )) && note "[Quick Test] Audio processing disabled (--skip-audio)"
  (( SKIP_SUBS  )) && note "[Quick Test] Subtitle processing disabled (--skip-subs)"

  # Cache metadata once for all operations
  cache_stream_metadata
  
  # Detect Dolby Vision
  if detect_dv; then
    IS_DV=1
    note "Dolby Vision detected — extraction/injection will be attempted in the video pipeline."
  else
    IS_DV=0
    note "No Dolby Vision detected."
  fi
  (( DISABLE_DV )) && note "DV handling explicitly disabled via --no-dv."

  # Decide color space and build x265 params
  decide_color_and_pixfmt "$SRC_ABS"
  build_x265_params
  [[ -n "$LEVEL_VALUE" ]] && apply_level_vbv "$LEVEL_VALUE"

  # Run pipelines
  if (( SKIP_VIDEO )); then
    die 42 "--skip-video is incompatible with producing a valid output file."
  else
    run_video_pipeline
  fi

  if (( SKIP_AUDIO )); then
    note "[Quick Test] --skip-audio: skipping audio selection/transcode"
    HAS_AUDIO=0
    A_PRIMARY=""
    AAC_STEREO=""
  else
    run_audio_pipeline
  fi

  build_subtitle_plan
  mux_final

  (( IS_DV == 1 && DISABLE_DV == 0 )) && note "Dolby Vision present in output (best-effort)." || note "Output is non-DV."

  say "→ Verifying output streams…"
  if (( DRY_RUN )); then
    say "DRY-RUN: ffprobe verify $TMP_OUT"
  else
    ffprobe -hide_banner -show_streams "$TMP_OUT" 2>/dev/null | sed -n '1,220p' || true
  fi
  mark_done "Verify output"

  say "→ Output (temp) size:"
  (( DRY_RUN )) && say "DRY-RUN: size of $TMP_OUT" || filesize_pretty "$TMP_OUT"

  note "✅ Staging complete — will atomically move to: $OUT"
}

main "$@"