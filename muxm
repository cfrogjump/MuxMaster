  SUB_ENABLE_OCR            = $SUB_ENABLE_OCR
  SUB_OCR_TOOL              = $SUB_OCR_TOOL
  SUB_OCR_LANG              = $SUB_OCR_LANG

  [Output / Muxing]
  OUTPUT_EXT                = $OUTPUT_EXT
  INCLUDE_AUDIO_TITLES      = $INCLUDE_AUDIO_TITLES
  KEEP_CHAPTERS             = $KEEP_CHAPTERS
  STRIP_METADATA            = $STRIP_METADATA

  [Pipeline Control]
  SKIP_IF_IDEAL             = $SKIP_IF_IDEAL
  REPORT_JSON               = $REPORT_JSON
  DRY_RUN                   = $DRY_RUN
  CHECKSUM                  = $CHECKSUM
  KEEP_TEMP                 = $KEEP_TEMP
  KEEP_TEMP_ALWAYS          = $KEEP_TEMP_ALWAYS
  REPLACE_SOURCE            = $REPLACE_SOURCE
  FORCE_REPLACE_SOURCE      = $FORCE_REPLACE_SOURCE
EOF
  exit 0
}

(( PRINT_EFFCONF )) && print_effective_config

