  echo "# Profile (format presets)"
  echo "# ========================="
  echo ""
  echo "# Default profile to apply. CLI --profile overrides this value."
  echo "# Valid profiles: dv-archival, hdr10-hq, atv-directplay-hq, streaming, animation, universal"
  echo "# Profiles set many variables at once; CLI flags still override individual values."
  printf 'PROFILE_NAME="%s"\n' "$profile"
  echo ""

  echo ""
  echo "# ========================="
  echo "# Video (x265/x264) fundamentals"
  echo "# ========================="
  echo ""
  echo "# Video encoder: libx265 (default, HEVC) or libx264 (H.264, universal compat)"
  _V VIDEO_CODEC
  echo ""
  echo "# CRF (Constant Rate Factor): 0–51 (lower = higher quality, larger files)"
  echo "#   14–18: visually transparent  |  19–22: good balance  |  23–28: smaller files"
  _V CRF_VALUE
  echo ""
  echo "# Preset: speed/efficiency trade-off (faster → bigger files, slower → smaller)"
  echo "# Options: ultrafast, superfast, veryfast, faster, fast, medium, slow, slower, veryslow, placebo"
  _V PRESET_VALUE
  echo ""
  echo "# Base x265 params: advanced tuning as a single string"
  echo "# Keep values colon-separated. Override entirely if you know what you're doing."
  _V X265_PARAMS_BASE quoted
  echo ""
  echo "# Level/IDR constraint for compatibility (e.g., 5.1). Leave empty to let encoder decide."
  printf '#LEVEL_VALUE=5.1\n'
  echo ""
  echo "# Conservative VBV guardrails (apply when LEVEL_VALUE is set)"
  echo "#   1 = apply cautious vbv-maxrate/bufsize  |  0 = don't apply additional limits"
  printf '#CONSERVATIVE_VBV=1\n'
  echo ""
  echo "# Skip encode if source video already matches profile requirements"
  echo "#   1 = copy video stream if compliant (much faster)  |  0 = always re-encode"
  _V VIDEO_COPY_IF_COMPLIANT
  echo ""

  echo ""
  echo "# ========================="
  echo "# Pixel format / Chroma"
  echo "# ========================="
  echo ""
  echo "# Force chroma subsampling 4:2:0 (most Direct Play targets require 4:2:0)"
  echo "#   1 = downsample 4:2:2/4:4:4 → 4:2:0  |  0 = keep source chroma"
  _V FORCE_CHROMA_420
  echo ""
  echo "# SDR 10-bit policy: 1 = keep 10-bit if source is 10-bit SDR  |  0 = force 8-bit"
  _V SDR_USE_10BIT_IF_SRC_10BIT
  echo ""
  echo "# Target pixel format when HDR (HLG/HDR10/DV base) is detected"
  _V HDR_TARGET_PIXFMT
  echo ""

  echo ""
  echo "# ========================="
  echo "# Tone-mapping (HDR → SDR)"
  echo "# ========================="
  echo ""
  echo "# Tone-map HDR to SDR (used by the universal profile for max compatibility)"
  echo "#   1 = convert HDR/HLG sources to SDR  |  0 = preserve HDR (default)"
  _V TONEMAP_HDR_TO_SDR
  echo ""
  echo "# Tone-map filter chain: advanced ffmpeg filter string for HDR→SDR conversion."
  printf "#TONEMAP_FILTER='zscale=t=linear:npl=100,format=gbrpf32le,zscale=p=bt709,tonemap=tonemap=hable:desat=0,zscale=t=bt709:m=bt709:r=tv,format=yuv420p'\n"
  echo ""

  echo ""
  echo "# ========================="
  echo "# Threads / parallelism"
  echo "# ========================="
  echo ""
  echo "# Threads for ffmpeg (empty = let ffmpeg decide)"
  printf '#THREADS=\n'
  echo ""

  echo ""
  echo "# ========================="
  echo "# Dolby Vision handling"
  echo "# ========================="
  echo ""
  echo "# Disable DV handling entirely: 1 = ignore DV  |  0 = detect and process DV"
  _V DISABLE_DV
  echo ""
  echo "# Allow fallback if DV injection/conversion fails: 1 = continue  |  0 = fatal"
  _V ALLOW_DV_FALLBACK
  echo ""
  echo "# Try converting Profile 7 RPU → Profile 8.1 if direct inject fails"
  _V DV_CONVERT_TO_P81_IF_FAIL
  echo ""

  echo ""
  echo "# ========================="
  echo "# Audio selection strategy"
  echo "# ========================="
  echo ""
  echo "# Language preference list (comma-separated)"
  printf '#AUDIO_LANG_PREF=eng\n'
  echo ""
  echo "# Codec preference order (leftmost best)"
  printf '#AUDIO_CODEC_PREFERENCE=eac3,ac3,aac,alac,other\n'
  echo ""
  echo "# Force a specific audio track by index (0-based). Leave empty for auto."
  printf '#AUDIO_TRACK_OVERRIDE=\n'
  echo ""

  echo ""
  echo "# ========================="
  echo "# Audio transcode policy"
  echo "# ========================="
  echo ""
  echo "# Stereo AAC bitrate (when transcoding or creating a fallback)"
  _V STEREO_BITRATE
  echo ""
  echo "# Maximum output channels (caps E-AC-3 downmix target)"
  echo "#   6 = 5.1, 8 = 7.1"
  _V MAX_AUDIO_CHANNELS
  echo ""
  echo "# Add a stereo AAC fallback track when primary >2ch"
  _V ADD_STEREO_IF_MULTICH
  echo ""
  echo "# E-AC-3 bitrates for multichannel transcode"
  _V EAC3_BITRATE_5_1
  _V EAC3_BITRATE_7_1
  echo ""
  echo "# Force all audio to a specific codec (e.g., \"aac\" for universal playback)"
  _V AUDIO_FORCE_CODEC
  echo ""
  echo "# Allow lossless audio codecs (TrueHD, DTS-HD MA, FLAC) to pass through"
  echo "#   1 = copy lossless  |  0 = transcode to lossy"
  _V AUDIO_LOSSLESS_PASSTHROUGH
  echo ""
  echo "# Run stereo and primary audio jobs in parallel"
  printf '#PARALLEL_AUDIO=0\n'
  echo ""

  echo ""
  echo "# ========================="
  echo "# Subtitles"
  echo "# ========================="
  echo ""
  echo "# Language preference for subtitle track selection (comma-separated)"
  printf '#SUB_LANG_PREF=eng\n'
  echo ""
  echo "# Include forced subtitles (foreign dialogue, signs)"
  _V SUB_INCLUDE_FORCED
  echo ""
  echo "# Include full (non-forced) subtitle tracks"
  _V SUB_INCLUDE_FULL
  echo ""
  echo "# Include SDH/HI (subtitles for the deaf and hard of hearing)"
  _V SUB_INCLUDE_SDH
  echo ""
  echo "# Maximum subtitle tracks to include in output"
  _V SUB_MAX_TRACKS
  echo ""
  echo "# Burn forced subtitles into the video stream (hardcoded, cannot be turned off)"
  _V SUB_BURN_FORCED
  echo ""
  echo "# Export non-forced subtitles as external .srt files alongside output"
  _V SUB_EXPORT_EXTERNAL
  echo ""
  # Detect available OCR tools on this machine
  local _detected_ocr_tool=""
  local _has_tesseract=0
  command -v tesseract >/dev/null 2>&1 && _has_tesseract=1
  if command -v pgsrip >/dev/null 2>&1 && (( _has_tesseract )); then
    _detected_ocr_tool="pgsrip"
  elif command -v sub2srt >/dev/null 2>&1; then
    _detected_ocr_tool="sub2srt"
  elif command -v pgsrip >/dev/null 2>&1; then
    # pgsrip found but tesseract missing — note it but still select it;
    # the runtime OCR-validation check (Section 8) will warn if tesseract
    # is still absent at encode time.
    _detected_ocr_tool="pgsrip"
  fi

  echo "# Enable OCR for bitmap subtitles (PGS/VobSub → SRT)"
  echo "# MP4 cannot carry PGS bitmaps; OCR converts them to text-based SRT."
  echo "#   1 = attempt OCR  |  0 = drop bitmap subtitles that can't be embedded"
  if [[ -n "$_detected_ocr_tool" ]]; then
    printf 'SUB_ENABLE_OCR=1\n'
  else
    printf '#SUB_ENABLE_OCR=1\n'
  fi
  echo ""
  echo "# OCR tool for bitmap → text subtitle conversion"
  echo "# Supported: \"sub2srt\", \"pgsrip\""
  echo "# pgsrip requires: pgsrip (pipx) + tesseract. Install via --install-dependencies."
  if [[ -n "$_detected_ocr_tool" ]]; then
    printf '# Auto-detected: %s found on this machine at config-generation time.\n' "$_detected_ocr_tool"
    printf 'SUB_OCR_TOOL=%s\n' "$_detected_ocr_tool"
  else
    printf '# No OCR tool detected. Install pgsrip or sub2srt and regenerate, or uncomment manually.\n'
    printf '#SUB_OCR_TOOL=sub2srt\n'
  fi
  echo ""
  echo "# OCR language for Tesseract (ISO 639-3, e.g., eng, fra, deu)"
  printf '#SUB_OCR_LANG=eng\n'
  echo ""

  echo ""
  echo "# ========================="
  echo "# Mux / output container"
  echo "# ========================="
  echo ""
  echo "# Output extension: mp4|m4v|mov|mkv"
  _V OUTPUT_EXT
  echo ""
  echo "# Keep chapter markers in output"
  _V KEEP_CHAPTERS
  echo ""
  echo "# Strip non-essential metadata from output"
  _V STRIP_METADATA
  echo ""

  echo ""
  echo "# ========================="
  echo "# Operational controls"
  echo "# ========================="
  echo ""
  echo "# Write a SHA-256 checksum next to final output"
  printf '#CHECKSUM=0\n'
  echo ""
  echo "# Dry-run: plan the steps without generating real outputs"
  printf '#DRY_RUN=0\n'
  echo ""
  echo "# Skip processing if source already matches profile requirements"
  _V SKIP_IF_IDEAL
  echo ""
  echo "# Generate a JSON report alongside output"
  _V REPORT_JSON
  echo ""

  echo ""
  echo "# ========================="
  echo "# ffmpeg / ffprobe UX"
  echo "# ========================="
  echo ""
  echo "# Hide ffmpeg banner: 1 = hide  |  0 = show"
  printf '#FFMPEG_HIDE_BANNER=1\n'
  echo ""
  echo "# ffmpeg log level: quiet|panic|fatal|error|warning|info|verbose|debug|trace"
  printf '#FFMPEG_LOGLEVEL=error\n'
  echo ""
  echo "# Overwrite outputs without prompting"
  printf '#FFMPEG_OVERWRITE=1\n'
  echo ""
  echo "# ffprobe log level"
  printf '#FFPROBE_LOGLEVEL=error\n'

  unset -f _V
}

_create_config() {
  local scope="$1"
  local profile="${2:-atv-directplay-hq}"
  local force="${3:-0}"

  # Validate scope → target path
  local target_path
  case "$scope" in
    system)  target_path="/etc/.muxmrc" ;;
    user)    target_path="$HOME/.muxmrc" ;;
    project) target_path="$PWD/.muxmrc" ;;
    *)
      printf '❌ ERROR: Invalid scope: %s\n' "$scope" >&2
      printf '   Valid scopes: system, user, project\n' >&2
      printf '   system  → /etc/.muxmrc\n' >&2
      printf '   user    → ~/.muxmrc\n' >&2
      printf '   project → %s/.muxmrc\n' "$PWD" >&2
      exit 11
      ;;
  esac

  # Validate profile
  case "$profile" in
    dv-archival|hdr10-hq|atv-directplay-hq|streaming|animation|universal) ;;
    *)
      printf '❌ ERROR: Unknown profile: %s\n' "$profile" >&2
      printf '   Valid profiles: dv-archival, hdr10-hq, atv-directplay-hq, streaming, animation, universal\n' >&2
      exit 11
      ;;
  esac

  # Check for existing file (refuse unless --force-create-config)
  if [[ -f "$target_path" ]] && (( ! force )); then
    printf '❌ ERROR: Config file already exists: %s\n' "$target_path" >&2
    printf '   To overwrite, use --force-create-config instead of --create-config.\n' >&2
    printf '   Or remove the file manually:  rm %s\n' "$target_path" >&2
    exit 1
  fi

  # Check write permissions
  local target_dir
  target_dir="$(dirname "$target_path")"
  if [[ ! -w "$target_dir" ]]; then
    printf '❌ ERROR: No write permission for %s\n' "$target_dir" >&2
    if [[ "$scope" == "system" ]]; then
      printf '   Try: sudo muxm --create-config system %s\n' "$profile" >&2
    fi
    exit 1
  fi

  # Generate the config file
  _create_config_emit "$profile" > "$target_path"

  printf '✅ Created %s config → %s\n' "$profile" "$target_path"
  printf '   Profile: %s\n' "$profile"
  printf '   Scope:   %s\n' "$scope"
  printf '\n'
  printf '   Profile-specific variables are uncommented and active.\n'
  printf '   All other variables are commented — uncomment to customize.\n'
  printf '   CLI flags always override config-file values.\n'
  printf '\n'

  # Report detected subtitle OCR tools
  local _det_ocr=""
  if command -v pgsrip >/dev/null 2>&1; then _det_ocr="pgsrip"; fi
  if command -v sub2srt >/dev/null 2>&1; then _det_ocr="${_det_ocr:+$_det_ocr, }sub2srt"; fi
  if [[ -n "$_det_ocr" ]]; then
    printf '   🔍 Detected OCR tools: %s\n' "$_det_ocr"
    printf '      SUB_ENABLE_OCR and SUB_OCR_TOOL set automatically.\n'
  else
    printf '   ⚠️  No subtitle OCR tools detected (pgsrip, sub2srt).\n'
    printf '      PGS/bitmap subtitles will be dropped unless you install one.\n'
    printf '      Run: muxm --install-dependencies\n'
  fi
  exit 0
}

# Pre-scan for --create-config / --force-create-config is below in Section 6b,
# after profile functions are defined (they're needed by the config generator).


# ===== Section 6b: Profile pre-scan & application ==============================================
# Two-pass CLI: first extract --profile, apply it, then let full CLI parse override.
#
# Precedence for PROFILE_NAME:
#   1. /etc/.muxmrc, ~/.muxmrc, ./.muxmrc  — may set PROFILE_NAME (lowest)
#   2. CLI --profile <n>                    — overrides config-file value (highest)
#
# Users can set a default profile in any .muxmrc file:
#   PROFILE_NAME="atv-directplay-hq"
# CLI --profile always overrides a config-file PROFILE_NAME.

# Track where the profile originated (for diagnostics / conflict warnings)
_PROFILE_SOURCE=""
if [[ -n "${PROFILE_NAME:-}" ]]; then
  _PROFILE_SOURCE="config-file"
fi

# Pre-scan: walk args looking only for --profile <n>
_prescan_args=("$@")
_filtered_args=()
_i=0
while (( _i < ${#_prescan_args[@]} )); do
  if [[ "${_prescan_args[$_i]}" == "--profile" ]]; then
    if (( _i + 1 < ${#_prescan_args[@]} )); then
      PROFILE_NAME="${_prescan_args[$((_i+1))]}"
      _PROFILE_SOURCE="cli"
      _i=$((_i + 2))
    else
      die 11 "--profile requires a profile name (dv-archival, hdr10-hq, atv-directplay-hq, streaming, animation, universal)"
    fi
  else
    _filtered_args+=("${_prescan_args[$_i]}")
    _i=$((_i + 1))
  fi
done
# Replace positional parameters with filtered args (--profile consumed)
set -- "${_filtered_args[@]}"
unset _prescan_args _filtered_args _i

# ---- Profile application functions (pure assignment, no side effects) ----

apply_profile_dv_archival() {
  # Goal: Preserve DV + HDR10 metadata, lossless audio, lossless remux only.
  DISABLE_DV=0
  ALLOW_DV_FALLBACK=1
  DV_CONVERT_TO_P81_IF_FAIL=1
  # Container: auto (keep source extension; default to mkv for broad codec support)
  OUTPUT_EXT="mkv"
  # Video: copy, don't re-encode
  VIDEO_COPY_IF_COMPLIANT=1
  VIDEO_CODEC="libx265"
  # Audio: lossless passthrough, no stereo fallback by default
  AUDIO_LOSSLESS_PASSTHROUGH=1
  ADD_STEREO_IF_MULTICH=0
  # Subs: keep all; no burn
  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=1
  SUB_BURN_FORCED=0
  SUB_EXPORT_EXTERNAL=0
  # Chapters/metadata: keep
  KEEP_CHAPTERS=1
  STRIP_METADATA=0
  # Skip-if-ideal: on
  SKIP_IF_IDEAL=1
  # Reporting: JSON
  REPORT_JSON=1
}

apply_profile_hdr10_hq() {
  # Goal: Max HDR10 quality, strip DV, preserve lossless audio + stereo fallback.
  DISABLE_DV=1
  ALLOW_DV_FALLBACK=0
  DV_CONVERT_TO_P81_IF_FAIL=0
  # Container: mkv
  OUTPUT_EXT="mkv"
  # Video: HEVC re-encode with high-quality HDR10 params
  VIDEO_CODEC="libx265"
  VIDEO_COPY_IF_COMPLIANT=0
  CRF_VALUE=17
  PRESET_VALUE="slower"
  X265_PARAMS_BASE='profile=main10:repeat-headers=1:hdr-opt=1:hdr10=1:hdr10-opt=1:colorprim=bt2020:transfer=smpte2084:colormatrix=bt2020nc:range=limited:aq-mode=3:aq-strength=1.3:psy-rd=2.0:psy-rdoq=1.0:rc-lookahead=60'
  HDR_TARGET_PIXFMT="yuv420p10le"
  FORCE_CHROMA_420=1
  # Audio: lossless passthrough + stereo fallback
  AUDIO_LOSSLESS_PASSTHROUGH=1
  ADD_STEREO_IF_MULTICH=1
  STEREO_BITRATE="256k"
  # Subs: keep all; no burn
  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=1
  SUB_BURN_FORCED=0
  # Chapters/metadata: keep
  KEEP_CHAPTERS=1
  STRIP_METADATA=0
}

apply_profile_atv_directplay_hq() {
  # Goal: Conform to Apple TV/Plex Direct Play constraints while keeping high quality.
  DISABLE_DV=0
  ALLOW_DV_FALLBACK=1
  DV_CONVERT_TO_P81_IF_FAIL=1
  # Container: mp4 for ATV Direct Play
  OUTPUT_EXT="mp4"
  # Video: prefer copy if compliant; else HEVC Main10
  VIDEO_CODEC="libx265"
  VIDEO_COPY_IF_COMPLIANT=1
  CRF_VALUE=17
  PRESET_VALUE="slower"
  X265_PARAMS_BASE='profile=main10:repeat-headers=1:hdr-opt=1:hdr10=1:hdr10-opt=1:aq-mode=3:aq-strength=1.3:psy-rd=2.0:psy-rdoq=1.0:rc-lookahead=60'
  HDR_TARGET_PIXFMT="yuv420p10le"
  FORCE_CHROMA_420=1
  # Audio: E-AC-3 for surround (ATV can't Direct Play TrueHD), AAC stereo fallback
  AUDIO_LOSSLESS_PASSTHROUGH=0
  ADD_STEREO_IF_MULTICH=1
  STEREO_BITRATE="256k"
  EAC3_BITRATE_5_1="640k"
  EAC3_BITRATE_7_1="768k"
  # Subs: burn forced (or mov_text); keep others as mov_text
  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=1
  SUB_BURN_FORCED=1
  SUB_EXPORT_EXTERNAL=0
  # Chapters/metadata: keep
  KEEP_CHAPTERS=1
  STRIP_METADATA=0
  # Skip-if-ideal: on
  SKIP_IF_IDEAL=1
}

apply_profile_universal() {
  # Goal: Compatibility over fidelity. SDR H.264, AAC stereo, burn forced subs.
  DISABLE_DV=1
  ALLOW_DV_FALLBACK=0
  DV_CONVERT_TO_P81_IF_FAIL=0
  # Container: mp4
  OUTPUT_EXT="mp4"
  # Video: H.264 SDR, tone-map HDR if present
  VIDEO_CODEC="libx264"
  VIDEO_COPY_IF_COMPLIANT=0
  TONEMAP_HDR_TO_SDR=1
  CRF_VALUE=22
  PRESET_VALUE="slow"
  FORCE_CHROMA_420=1
  # Audio: AAC stereo forced; optional AC3 5.1
  AUDIO_FORCE_CODEC="aac"
  AUDIO_LOSSLESS_PASSTHROUGH=0
  ADD_STEREO_IF_MULTICH=0
  MAX_AUDIO_CHANNELS=2
  STEREO_BITRATE="256k"
  # Subs: burn forced; export others as external SRT
  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=0
  SUB_BURN_FORCED=1
  SUB_EXPORT_EXTERNAL=1
  # Chapters/metadata: strip
  KEEP_CHAPTERS=0
  STRIP_METADATA=1
}

apply_profile_streaming() {
  # Goal: Smaller files, broad modern-device support, good quality.
  DISABLE_DV=1
  ALLOW_DV_FALLBACK=0
  DV_CONVERT_TO_P81_IF_FAIL=0
  # Container: mp4
  OUTPUT_EXT="mp4"
  # Video: HEVC re-encode targeting streaming file sizes
  VIDEO_CODEC="libx265"
  VIDEO_COPY_IF_COMPLIANT=0
  CRF_VALUE=20
  PRESET_VALUE="medium"
  X265_PARAMS_BASE='profile=main10:repeat-headers=1:hdr-opt=1:hdr10=1:hdr10-opt=1:aq-mode=3:aq-strength=1.3:psy-rd=2.0:psy-rdoq=1.0:rc-lookahead=60'
  HDR_TARGET_PIXFMT="yuv420p10le"
  FORCE_CHROMA_420=1
  # Audio: E-AC-3 surround (streaming bitrates), AAC stereo fallback
  AUDIO_LOSSLESS_PASSTHROUGH=0
  ADD_STEREO_IF_MULTICH=1
  STEREO_BITRATE="192k"
  EAC3_BITRATE_5_1="448k"
  EAC3_BITRATE_7_1="640k"
  # Subs: soft forced, full embedded, no SDH
  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=0
  SUB_BURN_FORCED=0
  SUB_EXPORT_EXTERNAL=0
  # Chapters/metadata: keep
  KEEP_CHAPTERS=1
  STRIP_METADATA=0
}

apply_profile_animation() {
  # Goal: Banding-free, artifact-free animation. Preserve flat gradients and hard edges.
  DISABLE_DV=1
  ALLOW_DV_FALLBACK=0
  DV_CONVERT_TO_P81_IF_FAIL=0
  # Container: mkv (ASS/SSA subtitle support, lossless audio)
  OUTPUT_EXT="mkv"
  # Video: HEVC, quality-first, animation-tuned x265 params
  VIDEO_CODEC="libx265"
  VIDEO_COPY_IF_COMPLIANT=0
  CRF_VALUE=16
  PRESET_VALUE="slower"
  X265_PARAMS_BASE='profile=main10:repeat-headers=1:aq-mode=3:aq-strength=0.8:psy-rd=1.0:psy-rdoq=0.5:rc-lookahead=60:deblock=-1,-1:bframes=8'
  HDR_TARGET_PIXFMT="yuv420p10le"
  FORCE_CHROMA_420=1
  SDR_USE_10BIT_IF_SRC_10BIT=1
  # Audio: lossless passthrough + stereo fallback
  AUDIO_LOSSLESS_PASSTHROUGH=1
  ADD_STEREO_IF_MULTICH=1
  STEREO_BITRATE="192k"
  # Subs: keep all, never burn (preserve ASS styling)
  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=1
  SUB_MAX_TRACKS=6
  SUB_BURN_FORCED=0
  SUB_EXPORT_EXTERNAL=0
  # Chapters/metadata: keep (OP/ED chapter markers)
  KEEP_CHAPTERS=1
  STRIP_METADATA=0
}

# Dispatcher
apply_profile() {
  [[ -z "${PROFILE_NAME:-}" ]] && return 0
  case "$PROFILE_NAME" in
    dv-archival)         apply_profile_dv_archival ;;
    hdr10-hq)            apply_profile_hdr10_hq ;;
    atv-directplay-hq)   apply_profile_atv_directplay_hq ;;
    streaming)           apply_profile_streaming ;;
    animation)           apply_profile_animation ;;
    universal)           apply_profile_universal ;;
    *)
      printf "❌ ERROR: Unknown profile: %s\n" "$PROFILE_NAME" >&2
      printf "   Valid profiles: dv-archival, hdr10-hq, atv-directplay-hq, streaming, animation, universal\n" >&2
      exit 11
      ;;
  esac
  note "Applied profile: $PROFILE_NAME (source: ${_PROFILE_SOURCE:-unknown})"
}

# Apply profile now (after config files, before CLI flags)
# But first: pre-scan for --create-config / --force-create-config.
# This must run after profile functions are defined (above) so the config
# generator can call them. It halts all other operations.
_cc_force=0
_cc_scope=""
_cc_profile=""
_cc_found=0
_cc_i=0
_cc_args=("$@")
while (( _cc_i < ${#_cc_args[@]} )); do
  case "${_cc_args[$_cc_i]}" in
    --create-config|--force-create-config)
      _cc_found=1
      [[ "${_cc_args[$_cc_i]}" == "--force-create-config" ]] && _cc_force=1
      # Next arg must be scope
      if (( _cc_i + 1 >= ${#_cc_args[@]} )); then
        printf '❌ ERROR: %s requires a scope: system, user, or project\n' "${_cc_args[$_cc_i]}" >&2
        printf '   Usage: muxm %s <system|user|project> [profile]\n' "${_cc_args[$_cc_i]}" >&2
        exit 11
      fi
      _cc_scope="${_cc_args[$((_cc_i + 1))]}"
      # Optional: profile as third arg
      if (( _cc_i + 2 < ${#_cc_args[@]} )) && [[ "${_cc_args[$((_cc_i + 2))]}" != -* ]]; then
        _cc_profile="${_cc_args[$((_cc_i + 2))]}"
      fi
      break
      ;;
  esac
  _cc_i=$((_cc_i + 1))
done
if (( _cc_found )); then
  _create_config "$_cc_scope" "$_cc_profile" "$_cc_force"
  # _create_config always exits; this line is unreachable
fi
unset _cc_force _cc_scope _cc_profile _cc_found _cc_i _cc_args

apply_profile

# ===== Section 7: CLI ==========================================================================
USAGE_SHORT="Usage: ${CLI_NAME} [options] <source> [target.${OUTPUT_EXT}]"
print_usage(){
  cat <<EOF
${APP_NAME} v${VERSION} — ${CLI_NAME}

$USAGE_SHORT

Profiles (--profile NAME):
  dv-archival          Preserve DV + HDR10 + lossless audio. MKV.
  hdr10-hq             Strip DV, keep HDR10. HEVC CRF 17. MKV.
  atv-directplay-hq    Apple TV Direct Play. MP4, DV P8.1, E-AC-3.
  streaming            HEVC streaming for Plex/Jellyfin. MP4.
  animation            Anime/cartoon optimized. 10-bit, lossless audio. MKV.
  universal            H.264 SDR, AAC stereo, play anywhere. MP4.

Common options:
  -h, --help                  Show this help
  -V, --version               Show version
  --profile NAME              Apply a format profile (overrides config defaults)
  --crf N                     Video quality (default: ${CRF_VALUE})
  -p, --preset NAME           x265 preset (default: ${PRESET_VALUE})
  --dry-run                   Plan steps without encoding
  --print-effective-config    Show resolved config and exit
  --install-dependencies      Install required tools via Homebrew/pipx
  --install-man               Install the muxm(1) manual page
  --uninstall-man             Remove the installed manual page
  --create-config SCOPE [PROFILE]
                              Generate .muxmrc (system|user|project)

See muxm(1) for the full option reference, profiles, and examples.
  Install:  muxm --install-man
  Then:     man muxm
EOF
}

print_version(){ echo "${APP_NAME} v${VERSION} (${CLI_NAME})"; }

is_valid_preset(){
  case "$1" in
    ultrafast|superfast|veryfast|faster|fast|medium|slow|slower|veryslow|placebo) return 0;;
    *) return 1;;
  esac
}

POSITIONALS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) print_usage; exit 0 ;;
    -V|--version) print_version; exit 0 ;;

    --print-effective-config) PRINT_EFFCONF=1; shift ;;

    -k|--keep-temp) KEEP_TEMP=1; shift ;;
    -K|--keep-temp-always) KEEP_TEMP_ALWAYS=1; shift ;;

    --dry-run) DRY_RUN=1; shift ;;
    --checksum) CHECKSUM=1; shift ;;
    --no-checksum) CHECKSUM=0; shift ;;

    --ffmpeg-loglevel) FFMPEG_LOGLEVEL="${2:-}"; shift 2 ;;
    --no-hide-banner) FFMPEG_HIDE_BANNER=0; shift ;;
    --no-overwrite) FFMPEG_OVERWRITE=0; shift ;;
    --ffprobe-loglevel) FFPROBE_LOGLEVEL="${2:-}"; shift 2 ;;
    --threads) THREADS="${2:-}"; shift 2 ;;

    --crf) CRF_VALUE="${2:-}"; shift 2 ;;
    -p|--preset)
      PRESET_VALUE="${2:-}"
      is_valid_preset "$PRESET_VALUE" || die 11 "Invalid preset: $PRESET_VALUE"
      shift 2
      ;;
    --x265-params) X265_PARAMS_BASE="${2:-}"; shift 2 ;;
    -l|--level) LEVEL_VALUE="${2:-}"; shift 2 ;;
    --no-conservative-vbv) CONSERVATIVE_VBV=0; shift ;;
    --no-dv) DISABLE_DV=1; shift ;;
    --allow-dv-fallback) ALLOW_DV_FALLBACK=1; shift ;;
    --no-allow-dv-fallback) ALLOW_DV_FALLBACK=0; shift ;;
    --dv-convert-p81) DV_CONVERT_TO_P81_IF_FAIL=1; shift ;;
    --no-dv-convert-p81) DV_CONVERT_TO_P81_IF_FAIL=0; shift ;;
    --video-codec)
      VIDEO_CODEC="${2:-}"
      case "$VIDEO_CODEC" in
        libx265|libx264) ;;
        *) die 11 "Invalid --video-codec: must be libx265 or libx264 (got: $VIDEO_CODEC)" ;;
      esac
      shift 2
      ;;
    --video-copy-if-compliant) VIDEO_COPY_IF_COMPLIANT=1; shift ;;
    --no-video-copy-if-compliant) VIDEO_COPY_IF_COMPLIANT=0; shift ;;
    --tonemap) TONEMAP_HDR_TO_SDR=1; shift ;;
    --no-tonemap) TONEMAP_HDR_TO_SDR=0; shift ;;

    --audio-track) AUDIO_TRACK_OVERRIDE="${2:-}"; shift 2 ;;
    --audio-lang-pref) AUDIO_LANG_PREF="${2:-}"; shift 2 ;;
    --stereo-bitrate) STEREO_BITRATE="${2:-}"; shift 2 ;;
    --stereo-fallback) ADD_STEREO_IF_MULTICH=1; shift ;;
    --no-stereo-fallback) ADD_STEREO_IF_MULTICH=0; shift ;;
    --audio-force-codec) AUDIO_FORCE_CODEC="${2:-}"; shift 2 ;;
    --audio-lossless-passthrough) AUDIO_LOSSLESS_PASSTHROUGH=1; shift ;;
    --no-audio-lossless-passthrough) AUDIO_LOSSLESS_PASSTHROUGH=0; shift ;;

    --no-subtitles) SUB_INCLUDE_FORCED=0; SUB_INCLUDE_FULL=0; SUB_INCLUDE_SDH=0; shift ;;
    --sub-lang-pref) SUB_LANG_PREF="${2:-}"; shift 2 ;;
    --no-sub-sdh) SUB_INCLUDE_SDH=0; shift ;;
    --ocr-lang) SUB_OCR_LANG="${2:-}"; shift 2 ;;
    --no-ocr) SUB_ENABLE_OCR=0; shift ;;
    --ocr-tool) SUB_OCR_TOOL="${2:-}"; shift 2 ;;
    --sub-burn-forced) SUB_BURN_FORCED=1; shift ;;
    --no-sub-burn-forced) SUB_BURN_FORCED=0; shift ;;
    --sub-export-external) SUB_EXPORT_EXTERNAL=1; shift ;;
    --no-sub-export-external) SUB_EXPORT_EXTERNAL=0; shift ;;

    --skip-video) SKIP_VIDEO=1; shift ;;
    --skip-audio) SKIP_AUDIO=1; shift ;;
    --skip-subs)  SKIP_SUBS=1;  shift ;;

    --output-ext) OUTPUT_EXT="${2:-}"; shift 2 ;;
    --keep-chapters) KEEP_CHAPTERS=1; shift ;;
    --no-keep-chapters) KEEP_CHAPTERS=0; shift ;;
    --strip-metadata) STRIP_METADATA=1; shift ;;
    --no-strip-metadata) STRIP_METADATA=0; shift ;;
    --skip-if-ideal) SKIP_IF_IDEAL=1; shift ;;
    --no-skip-if-ideal) SKIP_IF_IDEAL=0; shift ;;
    --report-json) REPORT_JSON=1; shift ;;
    --no-report-json) REPORT_JSON=0; shift ;;

    # --profile was consumed by pre-scan; handle straggler gracefully
    --profile) shift 2 ;;

    --) shift; break ;;
    -*) die 11 "Unknown option: $1. $USAGE_SHORT" ;;
    *) POSITIONALS+=("$1"); shift ;;
  esac
done

# ===== Section 7b: Profile + flag conflict warnings ============================================
# These are warnings, not errors — the user's explicit CLI flags always win.
# Conflicts are only checked when a profile is active.

_warn_conflict() {
  local profile="$1" flag="$2" reason="$3"
  warn "Profile '$profile' + $flag: $reason"
}

if [[ -n "${PROFILE_NAME:-}" ]]; then
  case "$PROFILE_NAME" in

    dv-archival)
      # DV archival without DV is pointless
      (( DISABLE_DV )) && \
        _warn_conflict "$PROFILE_NAME" "--no-dv" \
          "DV archival without Dolby Vision is pointless. Output will be a plain remux."

      # dv-archival is copy-only; setting CRF implies the user wants to re-encode
      if [[ "$_PROFILE_SOURCE" == "cli" ]] && [[ "$CRF_VALUE" -ne 18 ]]; then
        _warn_conflict "$PROFILE_NAME" "--crf $CRF_VALUE" \
          "dv-archival is designed for copy-only (no re-encode). CRF is ignored when VIDEO_COPY_IF_COMPLIANT succeeds."
      fi

      # Stripping metadata defeats archival purpose
      (( STRIP_METADATA )) && \
        _warn_conflict "$PROFILE_NAME" "--strip-metadata" \
          "Stripping metadata conflicts with archival goals. Metadata will be stripped as requested."

      # Stripping chapters defeats archival purpose
      (( ! KEEP_CHAPTERS )) && \
        _warn_conflict "$PROFILE_NAME" "--no-keep-chapters" \
          "Stripping chapters conflicts with archival goals. Chapters will be stripped as requested."

      # Burning subs defeats archival purpose (irreversible)
      (( SUB_BURN_FORCED )) && \
        _warn_conflict "$PROFILE_NAME" "--sub-burn-forced" \
          "Burning subtitles is irreversible and conflicts with archival goals."
      ;;

    hdr10-hq)
      # hdr10-hq sets DISABLE_DV=1 by default; if someone re-enabled it, warn
      (( ! DISABLE_DV )) && \
        _warn_conflict "$PROFILE_NAME" "(DV enabled)" \
          "hdr10-hq expects DV to be stripped. DV layers may cause unexpected behavior."

      # Tone-mapping makes no sense for HDR output
      (( TONEMAP_HDR_TO_SDR )) && \
        _warn_conflict "$PROFILE_NAME" "--tonemap" \
          "Tone-mapping HDR to SDR conflicts with HDR10 output. Output will be SDR."

      # H.264 codec is wrong for HDR10
      [[ "$VIDEO_CODEC" == "libx264" ]] && \
        _warn_conflict "$PROFILE_NAME" "--video-codec libx264" \
          "H.264 cannot carry HDR10 metadata. Use libx265 for HDR10 output."
      ;;

    atv-directplay-hq)
      # MKV won’t Direct Play on Apple TV
      [[ "$OUTPUT_EXT" == "mkv" ]] && \
        _warn_conflict "$PROFILE_NAME" "--output-ext mkv" \
          "MKV does not Direct Play on Apple TV. Use mp4 for ATV compatibility."

      # MOV is unusual but works
      [[ "$OUTPUT_EXT" == "mov" ]] && \
        _warn_conflict "$PROFILE_NAME" "--output-ext mov" \
          "MOV may work on Apple TV but mp4 is recommended for broadest Direct Play."

      # Tone-mapping defeats HDR purpose
      (( TONEMAP_HDR_TO_SDR )) && \
        _warn_conflict "$PROFILE_NAME" "--tonemap" \
          "Tone-mapping to SDR removes HDR. Apple TV supports HDR natively."

      # H.264 loses HDR + DV
      [[ "$VIDEO_CODEC" == "libx264" ]] && \
        _warn_conflict "$PROFILE_NAME" "--video-codec libx264" \
          "H.264 cannot carry HDR10/DV. Apple TV supports HEVC; use libx265."

      # Lossless audio won’t Direct Play on ATV
      (( AUDIO_LOSSLESS_PASSTHROUGH )) && \
        _warn_conflict "$PROFILE_NAME" "--audio-lossless-passthrough" \
          "TrueHD/DTS-HD MA won’t Direct Play on Apple TV. E-AC-3 is recommended."
      ;;

    streaming)
      # MKV is unusual for streaming targets
      [[ "$OUTPUT_EXT" == "mkv" ]] && \
        _warn_conflict "$PROFILE_NAME" "--output-ext mkv" \
          "MKV is unusual for streaming targets. MP4 recommended for broadest client support."

      # MOV is unusual for streaming targets
      [[ "$OUTPUT_EXT" == "mov" ]] && \
        _warn_conflict "$PROFILE_NAME" "--output-ext mov" \
          "MOV is unusual for streaming targets. MP4 recommended for broadest client support."

      # Lossless audio increases file size significantly
      (( AUDIO_LOSSLESS_PASSTHROUGH )) && \
        _warn_conflict "$PROFILE_NAME" "--audio-lossless-passthrough" \
          "Lossless audio increases file size significantly. E-AC-3/AAC recommended for streaming."

      # H.264 cannot carry HDR10
      [[ "$VIDEO_CODEC" == "libx264" ]] && \
        _warn_conflict "$PROFILE_NAME" "--video-codec libx264" \
          "H.264 cannot carry HDR10 metadata. HEVC recommended for streaming."
      ;;

    animation)
      # MP4 cannot carry styled ASS/SSA subtitles
      [[ "$OUTPUT_EXT" == "mp4" ]] && \
        _warn_conflict "$PROFILE_NAME" "--output-ext mp4" \
          "MP4 cannot carry styled ASS/SSA subtitles. MKV recommended for animation."

      # MOV has similar subtitle limitations
      [[ "$OUTPUT_EXT" == "mov" ]] && \
        _warn_conflict "$PROFILE_NAME" "--output-ext mov" \
          "MOV cannot carry styled ASS/SSA subtitles. MKV recommended for animation."

      # Burning subs destroys ASS styling
      (( SUB_BURN_FORCED )) && \
        _warn_conflict "$PROFILE_NAME" "--sub-burn-forced" \
          "Burning subs destroys ASS styling (typesetting, signs, karaoke). Soft subs recommended."

      # H.264 8-bit causes banding in animation
      [[ "$VIDEO_CODEC" == "libx264" ]] && \
        _warn_conflict "$PROFILE_NAME" "--video-codec libx264" \
          "H.264 8-bit causes visible banding in animation gradients. HEVC 10-bit recommended."

      # Transcoding lossless audio loses quality unnecessarily
      (( ! AUDIO_LOSSLESS_PASSTHROUGH )) && \
        _warn_conflict "$PROFILE_NAME" "--no-audio-lossless-passthrough" \
          "Transcoding lossless audio loses quality. MKV supports lossless natively."
      ;;

    universal)
      # MKV is unusual for max-compat
      [[ "$OUTPUT_EXT" == "mkv" ]] && \
        _warn_conflict "$PROFILE_NAME" "--output-ext mkv" \
          "MKV is unusual for max compatibility. MP4 recommended for widest device support."

      # MOV is unusual for max-compat
      [[ "$OUTPUT_EXT" == "mov" ]] && \
        _warn_conflict "$PROFILE_NAME" "--output-ext mov" \
          "MOV is unusual for max compatibility. MP4 recommended for widest device support."

      # Lossless passthrough defeats compatibility
      (( AUDIO_LOSSLESS_PASSTHROUGH )) && \
        _warn_conflict "$PROFILE_NAME" "--audio-lossless-passthrough" \
          "Lossless audio (TrueHD/DTS-HD MA) is not widely supported. AAC is recommended."

      # HEVC may not play everywhere
      [[ "$VIDEO_CODEC" == "libx265" ]] && \
        _warn_conflict "$PROFILE_NAME" "--video-codec libx265" \
          "HEVC is less widely supported than H.264 for universal playback."

      # Keeping DV enabled makes no sense for SDR universal output
      (( ! DISABLE_DV )) && \
        _warn_conflict "$PROFILE_NAME" "(DV enabled)" \
          "Dolby Vision in an SDR/H.264 universal output is contradictory. DV will be stripped."
      ;;

  esac

  # Cross-profile: warn on any flag combination that is inherently contradictory
  if (( TONEMAP_HDR_TO_SDR )) && [[ "$VIDEO_CODEC" == "libx265" ]]; then
    warn "Tone-mapping to SDR with HEVC output: SDR content in HEVC is valid but unusual. Consider libx264 for max compatibility."
  fi

  if (( VIDEO_COPY_IF_COMPLIANT )) && (( TONEMAP_HDR_TO_SDR )); then
    warn "VIDEO_COPY_IF_COMPLIANT + TONEMAP_HDR_TO_SDR: copy will be skipped when tone-mapping is needed."
  fi

  if (( SUB_BURN_FORCED )) && (( ! SUB_INCLUDE_FORCED )); then
    warn "SUB_BURN_FORCED=1 but SUB_INCLUDE_FORCED=0: no forced subtitles to burn."
  fi

  if (( SUB_EXPORT_EXTERNAL )) && [[ "$OUTPUT_EXT" == "mkv" ]]; then
    warn "SUB_EXPORT_EXTERNAL with MKV: MKV natively supports multiple subtitle tracks. External SRT export is unnecessary but will proceed as requested."
  fi
fi

# Global safeguard: H.264 cannot carry HDR metadata. If the user has selected
# libx264 without tone-mapping, HDR sources will produce washed-out output.
# This warning fires regardless of whether a profile is active.
if [[ "$VIDEO_CODEC" == "libx264" ]] && (( ! TONEMAP_HDR_TO_SDR )); then
  # We can't probe the source yet (no file parsed), so we note the risk.
  # The video pipeline will re-check once source HDR status is known.
  _H264_HDR_WARN_PENDING=1
else
  _H264_HDR_WARN_PENDING=0
fi


