# ===== Section 5: Basic helpers ===============================================================
# ---- Logging helpers ----
# All output goes to stderr to keep stdout clean for piping.
# say()  — plain informational message (no prefix)
# note() — informational with ℹ️  prefix
# warn() — warning with ⚠️  prefix
# die()  — fatal error with ❌ prefix; exits with code (default 1)
#           Usage: die "message" or die <code> "message"
say()  { printf "%s\n" "$@" >&2; }
note() { printf "ℹ️  %s\n" "$@" >&2; }
warn() { printf "⚠️  %s\n" "$@" >&2; }

# log() — write ONLY to the log file, not to the terminal.
# Falls back to say() if LOGFILE isn't set yet (pre–Section 12).
log() {
  if [[ -n "${LOGFILE:-}" && -w "${LOGFILE:-}" ]]; then
    printf "%s\n" "$@" >> "$LOGFILE"
  else
    say "$@"
  fi
}

# ---- Terminal FD for interactive UI (spinner / progress bar) ----
# Saved in Section 12 before the exec > >(tee …) redirect.
# Falls back to stderr if not yet initialised.
TERM_FD=""
# shellcheck disable=SC2059  # Callers pass printf format + args intentionally
_term_print() { printf -- "$@" >&"${TERM_FD:-2}"; }

# ---- Spinner — indeterminate progress indicator ----
# Usage: some_command & spinner $! "Doing something…"
# NOTE: spinner NEVER calls wait — it only polls with kill -0.
#       The caller MUST call wait "$pid" afterward to collect exit status.
spinner() {
  local pid=$1 msg=$2 i=0
  local -a sym=( '|' '/' '—' $'\\' )
  local -i show=1
  [[ -t ${TERM_FD:-2} ]] || show=0
  while kill -0 "$pid" 2>/dev/null; do
    (( show )) && _term_print '\r  %s  [ %s ]' "$msg" "${sym[i]}"
    i=$(( (i+1) % 4 ))
    sleep 0.2
  done
  (( show )) && _term_print '\r  %s  [ done ]\n' "$msg"
}

# run_with_spinner CMD_ARRAY_NAME "Message"
# Runs a command (passed as array name) in the background with a spinner.
# Returns the exit status of the background command.
run_with_spinner() {
  local -n _cmd_arr=$1
  local msg="$2"
  "${_cmd_arr[@]}" &
  local bg_pid=$!
  spinner "$bg_pid" "$msg"
  wait "$bg_pid" 2>/dev/null
  return $?
}

# ---- Progress bar — percentage-based for ffmpeg encodes ----
# Reads ffmpeg -progress output from a pipe and renders a bar.
# Args: $1 = ffmpeg PID, $2 = progress pipe path, $3 = total duration (seconds),
#       $4 = label
ffmpeg_progress_bar() {
  local pid=$1 pipe=$2 total_secs=$3 label=$4
  local pct=0 bar="" elapsed_us=0

  # If we can't show a progress bar (no terminal or unknown duration),
  # we MUST still drain the named pipe — otherwise ffmpeg blocks forever
  # trying to open the FIFO for writing with no reader on the other end.
  if [[ ! -t ${TERM_FD:-2} ]] || (( total_secs <= 0 )); then
    cat "$pipe" >/dev/null 2>&1 &
    spinner "$pid" "$label"
    wait "$pid" 2>/dev/null
    return $?
  fi

  local -i cols=40
  while IFS='=' read -r key val 2>/dev/null; do
    case "$key" in
      out_time_us)
        elapsed_us="${val:-0}"
        # Guard against non-numeric values
        [[ "$elapsed_us" =~ ^-?[0-9]+$ ]] || continue
        (( elapsed_us < 0 )) && elapsed_us=0
        pct=$(( elapsed_us * 100 / (total_secs * 1000000) ))
        (( pct > 100 )) && pct=100
        local filled empty
        filled=$(( pct * cols / 100 ))
        empty=$(( cols - filled ))
        bar="$(printf '%0.s█' $(seq 1 "$filled" 2>/dev/null) || true)"
        bar+="$(printf '%0.s░' $(seq 1 "$empty" 2>/dev/null) || true)"
        _term_print '\r  %s  [%s] %3d%%' "$label" "$bar" "$pct"
        ;;
      progress)
        # ffmpeg writes "progress=end" when done
        [[ "$val" == "end" ]] && break
        ;;
    esac
  done < "$pipe"

  # Ensure the bar reaches 100% visually
  bar="$(printf '%0.s█' $(seq 1 "$cols"))"
  _term_print '\r  %s  [%s] 100%%\n' "$label" "$bar"

  wait "$pid" 2>/dev/null
  return $?
}

# _get_source_duration_secs — extract source video duration in whole seconds.
#
# Three-tier lookup (each tier falls through on null, "N/A", or non-numeric):
#   1. streams[].duration           — standard per-stream field (MP4, TS)
#   2. format.duration              — container-level (requires -show_format in cache)
#   3. streams[].tags.DURATION      — Matroska/MKV tag, format "HH:MM:SS.nnnnnnnnn"
#
# Tier 3 is the most reliable for MKV sources: Matroska stores per-track duration
# in stream tags even when the standard duration field and Segment Duration are absent.
#
# Globals: METADATA_CACHE (read)
_get_source_duration_secs() {
  local dur=""

  # Tier 1: standard stream-level duration (common in MP4, rare in MKV)
  dur="$(printf '%s\n' "$METADATA_CACHE" | jq -r \
    '[.streams[] | select(.codec_type=="video")] | .[0].duration // empty' 2>/dev/null | head -n1)"
  if [[ "$dur" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
    log "Duration source: stream duration = ${dur}s"
    printf '%.0f\n' "$dur"
    return
  fi

  # Tier 2: container/format-level duration (most containers)
  dur="$(printf '%s\n' "$METADATA_CACHE" | jq -r \
    '.format.duration // empty' 2>/dev/null | head -n1)"
  if [[ "$dur" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
    log "Duration source: format duration = ${dur}s"
    printf '%.0f\n' "$dur"
    return
  fi

  # Tier 3: Matroska tags — DURATION as "HH:MM:SS.nnnnnnnnn"
  local tag_dur
  tag_dur="$(printf '%s\n' "$METADATA_CACHE" | jq -r \
    '[.streams[] | select(.codec_type=="video")] | .[0].tags.DURATION // empty' 2>/dev/null | head -n1)"
  if [[ "$tag_dur" =~ ^([0-9]+):([0-9]+):([0-9]+)(\.[0-9]+)?$ ]]; then
    local h="${BASH_REMATCH[1]}" m="${BASH_REMATCH[2]}" s="${BASH_REMATCH[3]}"
    dur=$(( 10#$h * 3600 + 10#$m * 60 + 10#$s ))
    log "Duration source: Matroska tag DURATION = ${tag_dur} → ${dur}s"
    echo "$dur"
    return
  fi

  log "Duration: unable to determine from stream, format, or Matroska tags — progress bar unavailable"
  echo 0
}

# Lowercase a string (avoids repeated inline tr calls)
_lower(){ printf '%s' "$1" | tr '[:upper:]' '[:lower:]'; }

die()  {
  local code=1
  if [[ $# -gt 1 && "$1" =~ ^[0-9]+$ ]]; then code="$1"; shift; fi
  FAILED=1; EXIT_CODE="$code"; FAIL_MSG="Fatal: $*"
  printf "❌ ERROR: %s\n" "$FAIL_MSG" >&2
  exit "$code"
}

on_error(){
  local lineno="$1" cmd="$2" status="$3"
  FAILED=1
  EXIT_CODE="${EXIT_CODE:-$status}"
  FAIL_MSG="Command failed at line $lineno: $cmd (exit $status)"
  printf "❌ ERROR: %s\n" "$FAIL_MSG" >&2
}

