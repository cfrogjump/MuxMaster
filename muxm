_install_man(){
  local mandir
  mandir="$(_man_target_dir)"
  local target="${mandir}/${CLI_NAME}.1"

  say "=== ${APP_NAME} v${VERSION} — Manual Page Installer ==="
  echo ""
  printf '  Target: %s\n' "$target"

  # Create directory if needed
  if [[ ! -d "$mandir" ]]; then
    printf '  📁 Creating %s ...\n' "$mandir"
    if [[ -w "$(dirname "$mandir")" ]]; then
      mkdir -p "$mandir"
    else
      sudo mkdir -p "$mandir"
    fi
  fi

  # Write the man page
  if [[ -w "$mandir" ]]; then
    _man_emit > "$target"
  else
    printf '  🔐 Requires elevated permissions.\n'
    _man_emit | sudo tee "$target" > /dev/null
  fi

  printf '  ✅ Installed %s\n' "$target"
  echo ""

  # Update man database if mandb/makewhatis available
  if command -v mandb >/dev/null 2>&1; then
    printf '  🔄 Updating man database ...\n'
    if [[ -w "$mandir" ]]; then
      mandb -q 2>/dev/null || true
    else
      sudo mandb -q 2>/dev/null || true
    fi
  fi

  printf '\n  View with: man %s\n' "$CLI_NAME"
  exit 0
}

_uninstall_man(){
  local mandir
  mandir="$(_man_target_dir)"
  local target="${mandir}/${CLI_NAME}.1"

  say "=== ${APP_NAME} v${VERSION} — Manual Page Uninstaller ==="
  echo ""

  if [[ ! -f "$target" ]]; then
    printf '  ⚠️  Man page not found at %s — nothing to remove.\n' "$target"
    exit 0
  fi

  printf '  Target: %s\n' "$target"
  if [[ -w "$mandir" ]]; then
    rm -f "$target"
  else
    printf '  🔐 Requires elevated permissions.\n'
    sudo rm -f "$target"
  fi

  printf '  ✅ Removed %s\n' "$target"
  exit 0
}

# Pre-scan for --install-man / --uninstall-man
for _arg in "$@"; do
  case "$_arg" in
    --install-man)   _install_man ;;
    --uninstall-man) _uninstall_man ;;
  esac
done
unset _arg
# Invoked via --create-config <scope> [profile]. Generates a .muxmrc file at the
# appropriate location with the full template and profile-specific variables
# uncommented. Halts all other operations.
#
# Scope → path:  system=/etc/.muxmrc  user=~/.muxmrc  project=$PWD/.muxmrc
# Profile:       defaults to atv-directplay-hq if omitted.
# --force-create-config: overwrite if file already exists.

_create_config_emit() {
  local profile="$1"

  # Build the set of variables that this profile explicitly sets.
  # These will be emitted uncommented; all others stay commented.
  local _active=" "
  case "$profile" in
    dv-archival)
      _active+="DISABLE_DV ALLOW_DV_FALLBACK DV_CONVERT_TO_P81_IF_FAIL "
      _active+="OUTPUT_EXT VIDEO_COPY_IF_COMPLIANT VIDEO_CODEC "
      _active+="AUDIO_LOSSLESS_PASSTHROUGH ADD_STEREO_IF_MULTICH "
      _active+="SUB_INCLUDE_FORCED SUB_INCLUDE_FULL SUB_INCLUDE_SDH SUB_BURN_FORCED SUB_EXPORT_EXTERNAL "
      _active+="KEEP_CHAPTERS STRIP_METADATA SKIP_IF_IDEAL REPORT_JSON "
      ;;
    hdr10-hq)
      _active+="DISABLE_DV ALLOW_DV_FALLBACK DV_CONVERT_TO_P81_IF_FAIL "
      _active+="OUTPUT_EXT VIDEO_CODEC VIDEO_COPY_IF_COMPLIANT CRF_VALUE PRESET_VALUE "
      _active+="X265_PARAMS_BASE HDR_TARGET_PIXFMT FORCE_CHROMA_420 "
      _active+="AUDIO_LOSSLESS_PASSTHROUGH ADD_STEREO_IF_MULTICH STEREO_BITRATE "
      _active+="SUB_INCLUDE_FORCED SUB_INCLUDE_FULL SUB_INCLUDE_SDH SUB_BURN_FORCED "
      _active+="KEEP_CHAPTERS STRIP_METADATA "
      ;;
    atv-directplay-hq)
      _active+="DISABLE_DV ALLOW_DV_FALLBACK DV_CONVERT_TO_P81_IF_FAIL "
      _active+="OUTPUT_EXT VIDEO_CODEC VIDEO_COPY_IF_COMPLIANT CRF_VALUE PRESET_VALUE "
      _active+="X265_PARAMS_BASE HDR_TARGET_PIXFMT FORCE_CHROMA_420 "
      _active+="AUDIO_LOSSLESS_PASSTHROUGH ADD_STEREO_IF_MULTICH STEREO_BITRATE "
      _active+="EAC3_BITRATE_5_1 EAC3_BITRATE_7_1 "
      _active+="SUB_INCLUDE_FORCED SUB_INCLUDE_FULL SUB_INCLUDE_SDH SUB_BURN_FORCED SUB_EXPORT_EXTERNAL "
      _active+="KEEP_CHAPTERS STRIP_METADATA SKIP_IF_IDEAL "
      ;;
    streaming)
      _active+="DISABLE_DV ALLOW_DV_FALLBACK DV_CONVERT_TO_P81_IF_FAIL "
      _active+="OUTPUT_EXT VIDEO_CODEC VIDEO_COPY_IF_COMPLIANT CRF_VALUE PRESET_VALUE "
      _active+="X265_PARAMS_BASE HDR_TARGET_PIXFMT FORCE_CHROMA_420 "
      _active+="AUDIO_LOSSLESS_PASSTHROUGH ADD_STEREO_IF_MULTICH STEREO_BITRATE "
      _active+="EAC3_BITRATE_5_1 EAC3_BITRATE_7_1 "
      _active+="SUB_INCLUDE_FORCED SUB_INCLUDE_FULL SUB_INCLUDE_SDH SUB_BURN_FORCED SUB_EXPORT_EXTERNAL "
      _active+="KEEP_CHAPTERS STRIP_METADATA "
      ;;
    animation)
      _active+="DISABLE_DV ALLOW_DV_FALLBACK DV_CONVERT_TO_P81_IF_FAIL "
      _active+="OUTPUT_EXT VIDEO_CODEC VIDEO_COPY_IF_COMPLIANT CRF_VALUE PRESET_VALUE "
      _active+="X265_PARAMS_BASE HDR_TARGET_PIXFMT FORCE_CHROMA_420 SDR_USE_10BIT_IF_SRC_10BIT "
      _active+="AUDIO_LOSSLESS_PASSTHROUGH ADD_STEREO_IF_MULTICH STEREO_BITRATE "
      _active+="SUB_INCLUDE_FORCED SUB_INCLUDE_FULL SUB_INCLUDE_SDH SUB_MAX_TRACKS SUB_BURN_FORCED SUB_EXPORT_EXTERNAL "
      _active+="KEEP_CHAPTERS STRIP_METADATA "
      ;;
    universal)
      _active+="DISABLE_DV ALLOW_DV_FALLBACK DV_CONVERT_TO_P81_IF_FAIL "
      _active+="OUTPUT_EXT VIDEO_CODEC VIDEO_COPY_IF_COMPLIANT TONEMAP_HDR_TO_SDR CRF_VALUE PRESET_VALUE "
      _active+="FORCE_CHROMA_420 "
      _active+="AUDIO_FORCE_CODEC AUDIO_LOSSLESS_PASSTHROUGH ADD_STEREO_IF_MULTICH MAX_AUDIO_CHANNELS STEREO_BITRATE "
      _active+="SUB_INCLUDE_FORCED SUB_INCLUDE_FULL SUB_INCLUDE_SDH SUB_BURN_FORCED SUB_EXPORT_EXTERNAL "
      _active+="KEEP_CHAPTERS STRIP_METADATA "
      ;;
  esac

  # Apply the profile to populate variable values
  PROFILE_NAME="$profile"
  "apply_profile_${profile//-/_}"

  # Helper: emit a variable — uncommented if active, commented otherwise.
  # Usage: _V VARNAME [quoted]
  # "quoted" wraps the value in single quotes (for strings with special chars).
  _V() {
    local var="$1" quote="${2:-}"
    local val="${!var}"
    if [[ "$_active" == *" ${var} "* ]]; then
      if [[ "$quote" == "quoted" ]]; then
        printf "%s='%s'\n" "$var" "$val"
      else
        printf '%s=%s\n' "$var" "$val"
      fi
    else
