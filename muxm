# ===== Section 1: Strict mode & debug =========================================================
set -eEuo pipefail
if shopt -q inherit_errexit 2>/dev/null; then shopt -s inherit_errexit; fi
[[ "${DEBUG:-0}" == "1" ]] && set -x

# ===== Section 2: Branding / CLI constants =====================================================
readonly APP_NAME="MuxMaster"
