# ===== Section 10: Config generator (--create-config / --force-create-config) =================
# Invoked via --create-config <scope> [profile]. Generates a .muxmrc file at the
# appropriate location with the full template and profile-specific variables
# uncommented. Halts all other operations.
#
# Scope → path:  system=/etc/.muxmrc  user=~/.muxmrc  project=$PWD/.muxmrc
# Profile:       defaults to atv-directplay-hq if omitted.
# --force-create-config: overwrite if file already exists.

# <<< embedded config template >>>
_create_config_emit() {
  local profile="$1"

  # Build the set of variables that this profile explicitly sets.
  # These will be emitted uncommented; all others stay commented.
  #
  # Shared base: variables set by ALL profiles (DV, container, video, audio, subs, output).
  # Per-profile deltas add profile-specific variables on top.
  # Space-padded set of "active" variable names for this profile.
  # _V checks membership via: [[ "$_active" == *" VARNAME "* ]]
  # Leading/trailing spaces ensure whole-word matching (prevents "FOO"
  # from matching "FOO_BAR"). Each name must be space-delimited.
  local _active=" "
  local _base="DISABLE_DV ALLOW_DV_FALLBACK DV_CONVERT_TO_P81_IF_FAIL "
  _base+="OUTPUT_EXT VIDEO_CODEC VIDEO_COPY_IF_COMPLIANT "
  _base+="AUDIO_LOSSLESS_PASSTHROUGH ADD_STEREO_IF_MULTICH STEREO_BITRATE "
  _base+="SUB_INCLUDE_FORCED SUB_INCLUDE_FULL SUB_INCLUDE_SDH SUB_BURN_FORCED "
  _base+="KEEP_CHAPTERS STRIP_METADATA "
  _active+="$_base"

  case "$profile" in
    dv-archival)
      _active+="SKIP_IF_IDEAL REPORT_JSON "
      _active+="AUDIO_CODEC_PREFERENCE "
      ;;
    hdr10-hq)
      _active+="CRF_VALUE PRESET_VALUE "
      _active+="X265_PARAMS_BASE HDR_TARGET_PIXFMT FORCE_CHROMA_420 "
      ;;
    atv-directplay-hq)
      _active+="CRF_VALUE PRESET_VALUE "
      _active+="X265_PARAMS_BASE HDR_TARGET_PIXFMT FORCE_CHROMA_420 "
      _active+="EAC3_BITRATE_5_1 EAC3_BITRATE_7_1 "
      _active+="MAX_COPY_BITRATE "
      _active+="SUB_EXPORT_EXTERNAL SKIP_IF_IDEAL "
      ;;
    atv-directplay-hq-nvenc)
      _active+="CRF_VALUE PRESET_VALUE "
      _active+="HDR_TARGET_PIXFMT FORCE_CHROMA_420 "
      _active+="EAC3_BITRATE_5_1 EAC3_BITRATE_7_1 "
      _active+="SUB_EXPORT_EXTERNAL "
      ;;
    streaming)
      _active+="CRF_VALUE PRESET_VALUE "
      _active+="X265_PARAMS_BASE HDR_TARGET_PIXFMT FORCE_CHROMA_420 "
      _active+="EAC3_BITRATE_5_1 EAC3_BITRATE_7_1 "
      _active+="SUB_EXPORT_EXTERNAL "
      ;;
    animation)
      _active+="CRF_VALUE PRESET_VALUE "
      _active+="X265_PARAMS_BASE HDR_TARGET_PIXFMT FORCE_CHROMA_420 SDR_USE_10BIT_IF_SRC_10BIT SDR_FORCE_10BIT "
      _active+="AUDIO_CODEC_PREFERENCE "
      _active+="SUB_MAX_TRACKS SUB_EXPORT_EXTERNAL "
      ;;
    universal)
      _active+="TONEMAP_HDR_TO_SDR CRF_VALUE PRESET_VALUE "
      _active+="FORCE_CHROMA_420 "
      _active+="AUDIO_FORCE_CODEC MAX_AUDIO_CHANNELS "
      _active+="SUB_EXPORT_EXTERNAL "
      ;;
  esac

  # Apply the profile to populate variable values
  PROFILE_NAME="$profile"
  "apply_profile_${profile//-/_}"

  # Helper: emit a variable — uncommented if it's in the _active set, commented otherwise.
  # Uses indirect expansion (${!var}) to read the variable's current value.
  # Membership test: _active is space-padded, so *" VARNAME "* matches whole names only.
  # Usage: _V VARNAME [quoted]
  # "quoted" wraps the value in single quotes (for strings with special chars).
  _V() {
    local var="$1" quote="${2:-}"
    local val="${!var}"
    if [[ "$_active" == *" ${var} "* ]]; then
      if [[ "$quote" == "quoted" ]]; then
        printf "%s='%s'\n" "$var" "$val"
      else
        printf '%s=%s\n' "$var" "$val"
      fi
    else
      if [[ "$quote" == "quoted" ]]; then
        printf "#%s='%s'\n" "$var" "$val"
      else
        printf '#%s=%s\n' "$var" "$val"
      fi
    fi
  }

  cat <<'HEADER'
# ================================================================
#  MuxMaster .muxmrc — configuration file
#  Generated by: muxm --create-config
#  Precedence: Script defaults → /etc/.muxmrc → ~/.muxmrc → ./.muxmrc → --profile → CLI flags
#  Tip: Uncomment a line to override. Keep values shell-safe.
# ================================================================
HEADER
  printf '# Profile: %s\n' "$profile"
  printf '# Generated: %s\n' "$(date '+%Y-%m-%d %H:%M:%S')"
  printf '#\n'
  printf '# Variables set by this profile are uncommented below.\n'
  printf '# All other variables are commented with their defaults — uncomment to customize.\n'
  echo ""

  echo "# ========================="
  echo "# Hardware Acceleration"
  echo "# ========================="
  echo ""
  echo "# Hardware acceleration type: nvidia|intel|apple|cpu"
  echo "# Auto-detected during 'muxm --setup' and cached here for future runs"
  printf '#HWACCEL_TYPE=%s\n' "${HWACCEL_TYPE:-cpu}"
  echo ""
  echo "# Enable hardware acceleration (1=enabled, 0=disabled)"
  printf '#HWACCEL_ENABLED=%s\n' "${HWACCEL_ENABLED:-0}"
  echo ""
  echo "# Enable hardware decode when available (1=enabled, 0=disabled)"
  printf '#HWACCEL_DECODE=1\n'
  echo ""
  echo "# Enable hardware encode when available (1=enabled, 0=disabled)"
  printf '#HWACCEL_ENCODE=1\n'
  echo ""

  echo "# ========================="
  echo "# Profile (format presets)"
  echo "# ========================="
  echo ""
  echo "# Default profile to apply. CLI --profile overrides this value."
  echo "# Valid profiles: $(_valid_profiles_display)"
  echo "# Profiles set many variables at once; CLI flags still override individual values."
  printf 'PROFILE_NAME="%s"\n' "$profile"
  echo ""

  echo ""
  echo "# ========================="
  echo "# Video (x265/x264) fundamentals"
  echo "# ========================="
  echo ""
  echo "# Video encoder: libx265 (default, HEVC) or libx264 (H.264, universal compat)"
  _V VIDEO_CODEC
  echo ""
  echo "# CRF (Constant Rate Factor): 0–51 (lower = higher quality, larger files)"
  echo "#   14–18: visually transparent  |  19–22: good balance  |  23–28: smaller files"
  _V CRF_VALUE
  echo ""
  echo "# Preset: speed/efficiency trade-off (faster → bigger files, slower → smaller)"
  echo "# Options: ultrafast, superfast, veryfast, faster, fast, medium, slow, slower, veryslow, placebo"
  _V PRESET_VALUE
  echo ""
  echo "# Base x265 params: advanced tuning as a single string"
  echo "# Keep values colon-separated. Override entirely if you know what you're doing."
  _V X265_PARAMS_BASE quoted
  echo ""
  echo "# Level/IDR constraint for compatibility (e.g., 5.1). Leave empty to let encoder decide."
  printf '#LEVEL_VALUE=5.1\n'
  echo ""
  echo "# Conservative VBV guardrails (apply when LEVEL_VALUE is set)"
  echo "#   1 = apply cautious vbv-maxrate/bufsize  |  0 = don't apply additional limits"
  printf '#CONSERVATIVE_VBV=1\n'
  echo ""
