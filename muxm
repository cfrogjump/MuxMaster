  fi
}
disk_free_warn

# ===== Section 20: Metadata caching & ffprobe helpers =========================================
# Cache all stream metadata in one call for performance
cache_stream_metadata() {
  log "→ Caching stream metadata..."
  METADATA_CACHE="$(ffprobe "${FFPROBE_FLAGS[@]}" -show_format -show_streams -of json "$SRC_ABS" 2>/dev/null)" || {
    die 12 "Failed to probe source file metadata - file may be corrupt"
  }
  # Validate JSON integrity before downstream helpers rely on it
