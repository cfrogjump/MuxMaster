# ===== Section 15: Input validation & security checks =========================================
SRC="${POSITIONALS[0]:-}"
OUT="${POSITIONALS[1]:-}"
(( ${#POSITIONALS[@]} > 2 )) && die 11 "Too many arguments. $USAGE_SHORT"
[[ -z "$SRC" ]] && { print_usage; exit 0; }

# Validate output extension (security: prevent command injection)
case "$OUTPUT_EXT" in
  mp4|m4v|mov|mkv) ;;
  *) die 11 "Invalid OUTPUT_EXT: must be mp4, m4v, mov, or mkv (got: $OUTPUT_EXT)" ;;
esac

# Resolve and validate source file
SRC_ABS="$(realpath_fallback "$SRC")"
[[ -f "$SRC_ABS" ]] || die 11 "Source file not found: $SRC_ABS"
[[ -s "$SRC_ABS" ]] || die 11 "Source file is empty: $SRC_ABS"
[[ -r "$SRC_ABS" ]] || die 11 "Source file not readable: $SRC_ABS"

# Validate filename doesn't contain control characters (security)
# This catches newlines, tabs, null bytes, and other chars that could cause
# field-splitting issues in the printf '%s\n' patterns used throughout.
if [[ "$SRC_ABS" =~ [[:cntrl:]] ]]; then
  die 11 "Source filename contains control characters - potential security risk"
fi

# Determine output path
if [[ -z "${OUT:-}" ]]; then
  base="${SRC_ABS%.*}"
  OUT="${base}.${OUTPUT_EXT}"
fi

# Resolve output directory and validate
OUT_DIR="$(dirname -- "$OUT")"
OUT_DIR="$(if cd -- "$OUT_DIR" 2>/dev/null; then pwd; else echo "$OUT_DIR"; fi)"
[[ -d "$OUT_DIR" ]] || die 11 "Output directory does not exist: $OUT_DIR"
[[ -w "$OUT_DIR" ]] || die 11 "Output directory not writable: $OUT_DIR"

OUT_BASENAME="$(basename -- "$OUT")"
OUT_ABS="${OUT_DIR}/${OUT_BASENAME}"
OUT="$OUT_ABS"

# Validate output doesn't contain control characters (security)
if [[ "$OUT_ABS" =~ [[:cntrl:]] ]]; then
  die 11 "Output filename contains control characters - potential security risk"
fi

# Prevent overwriting source file (security/safety)
# --replace-source / --force-replace-source: allow source replacement
# Otherwise: auto-version the output filename to avoid collision
declare -i _REPLACING_SOURCE=0
if [[ "$SRC_ABS" -ef "$OUT_ABS" ]]; then
  if (( FORCE_REPLACE_SOURCE )); then
    _REPLACING_SOURCE=1
    note "Source will be replaced (--force-replace-source): $SRC_ABS"
  elif (( REPLACE_SOURCE )); then
    printf '⚠️  Are you sure you want the original file replaced? (y/n) '
    read -r _confirm
    if [[ "$_confirm" == [Yy]* ]]; then
      _REPLACING_SOURCE=1
      note "Source will be replaced (confirmed): $SRC_ABS"
    else
      die 11 "Aborted — source replacement declined by user."
    fi
  else
    # Auto-version: filename(1).ext, filename(2).ext, ...
    _ver_base="${OUT_ABS%.*}"
    _ver_ext="${OUT_ABS##*.}"
    _ver=1
    OUT_ABS="${_ver_base}(${_ver}).${_ver_ext}"
    while [[ -e "$OUT_ABS" ]]; do
      (( _ver++ ))
      OUT_ABS="${_ver_base}(${_ver}).${_ver_ext}"
    done
    OUT_BASENAME="$(basename -- "$OUT_ABS")"
    OUT="$OUT_ABS"
    note "Source collision — output renamed to: $OUT_BASENAME"
  fi
fi

# --no-overwrite: refuse if final output already exists
if (( ! FFMPEG_OVERWRITE )) && [[ -f "$OUT_ABS" ]]; then
  die 11 "Output file already exists (--no-overwrite): $OUT_ABS"
fi

# Security: Use unpredictable temp file name.
# NOTE: mktemp creates the file, then we delete it and re-add the extension.
# There is a theoretical TOCTOU window between rm and ffmpeg's eventual open.
# This is acceptable because: (a) the window is microseconds, (b) exploitation
# requires local write access to OUT_DIR, (c) mktemp --suffix is not portable.
TMP_OUT="$(mktemp "$OUT_DIR/.muxm.output.XXXXXXXX")" || die 11 "Cannot create temp output file"
rm -f "$TMP_OUT"  # Remove the file, we just wanted the name
TMP_OUT="${TMP_OUT}.${OUTPUT_EXT}"

# Determine mux format
MUX_FORMAT="mp4"
case "$OUTPUT_EXT" in
  mp4|m4v) MUX_FORMAT="mp4" ;;
  mov)     MUX_FORMAT="mov" ;;
  mkv)     MUX_FORMAT="matroska" ;;
esac

# ===== Section 16: Build ffmpeg/ffprobe flags =================================================
FFMPEG_FLAGS=()
FFPROBE_FLAGS=()

(( FFMPEG_HIDE_BANNER )) && FFMPEG_FLAGS+=(-hide_banner)
FFMPEG_FLAGS+=(-loglevel "$FFMPEG_LOGLEVEL")
(( FFMPEG_OVERWRITE )) && FFMPEG_FLAGS+=(-y)

FFPROBE_FLAGS=(-v "$FFPROBE_LOGLEVEL")

PROBE_OPTS=(-analyzeduration 100M -probesize 100M)
FFMPEG_FLAGS+=("${PROBE_OPTS[@]}")
FFPROBE_FLAGS+=("${PROBE_OPTS[@]}")

# ===== Section 17: Workdir & logging ==========================================================
WORKDIR="$(
  mktemp -d "${OUT_DIR}/.muxm.tmp.XXXXXXXX"
)" || die 11 "Cannot create working directory under: $OUT_DIR"
LOGFILE="$WORKDIR/muxm.$(date +%Y%m%d-%H%M%S).log"

# ---- Begin logging to file ----
# Redirect stdout and stderr through tee to capture all output in the log file
# while still displaying it on the terminal.
#
# FD 3 is preserved as a "raw terminal" descriptor BEFORE the redirect. This
# allows spinner/progress-bar code to write \r-based updates directly to the
# terminal without polluting the log file with ANSI cursor movements.
#
# Lifecycle: FD 3 is opened here and closed in on_exit() (Section 19) during
# cleanup, completing the descriptor lifecycle.
#
# After this section:
#   stdout/stderr → tee → log file + terminal
#   FD 3          → raw terminal (bypasses tee)
if [[ "${DEBUG:-0}" != "1" ]]; then
  : > "$LOGFILE" 2>/dev/null || true
  # Preserve a raw terminal FD for spinner / progress-bar output.
  # After the exec redirect, stdout and stderr both go through tee → log + terminal.
  # FD 3 bypasses tee so \r-based progress UI doesn't pollute the log file.
  exec 3>&2
  TERM_FD=3
  exec > >(tee -a "$LOGFILE") 2>&1
  note "Logging to $(realpath_fallback "$LOGFILE")"
fi

# ===== Section 18: Traps ======================================================================
trap 'on_error $LINENO "$BASH_COMMAND" "$?"' ERR
trap 'FAILED=1; EXIT_CODE=130; FAIL_MSG="Interrupted by user (SIGINT)"; _term_print "\n"; exit 130' INT
trap 'FAILED=1; EXIT_CODE=143; FAIL_MSG="Terminated (SIGTERM)"; exit 143' TERM

_print_completed_steps(){
  [[ ${#COMPLETED_STEPS[@]} -gt 0 ]] || return 0
  echo "---- Completed steps ----"
  for s in "${COMPLETED_STEPS[@]}"; do echo "  • $s"; done
}

# on_exit — EXIT trap handler. Performs all end-of-run cleanup and reporting.
#
# Success path: atomically moves temp output to final path, writes checksum,
#   prints completed steps, cleans up workdir (unless --keep-temp-always).
# Failure path: prints failure message + completed steps, cleans up temp output,
#   preserves workdir for debugging (if --keep-temp or --keep-temp-always).
# Dry-run path: removes temp placeholder, reports completion.
#
# Globals read: FAILED, DRY_RUN, TMP_OUT, OUT, CHECKSUM, WORKDIR, DEBUG,
#               KEEP_TEMP, KEEP_TEMP_ALWAYS, EXIT_CODE, FAIL_MSG, TERM_FD
on_exit() {
  # Close the raw-terminal FD if it was opened (Section 17)
  [[ -n "${TERM_FD:-}" ]] && exec 3>&- 2>/dev/null || true

  # Clean up subtitle burn-in temp file (lives outside WORKDIR in /tmp)
  [[ -n "${_BURN_SRT_FILTER:-}" && -f "$_BURN_SRT_FILTER" ]] && rm -f "$_BURN_SRT_FILTER"

  local have_result=0
  
  if (( DRY_RUN )); then
    have_result=1
  elif [[ -n "${TMP_OUT:-}" && -s "$TMP_OUT" ]]; then
    have_result=1
  elif [[ -n "${OUT:-}" && -s "$OUT" ]]; then
    have_result=1
  fi

  if (( FAILED == 0 && have_result == 1 )); then
    if (( DRY_RUN )); then
      [[ -f "$TMP_OUT" ]] && rm -f "$TMP_OUT"
      note "DRY-RUN complete — no real files were created."
    else
      [[ -f "$TMP_OUT" ]] && mv -f "$TMP_OUT" "$OUT"
      # macOS/APFS sets the UF_HIDDEN (user hidden) flag on dot-prefixed files
      # at the filesystem level. Our temp file (.muxm.output.XXXXXXXX) inherits
      # this flag, and `mv` preserves it even after renaming to a non-dot name.
      # This causes Finder to treat the final output as hidden. Clear it here.
      # No-op on Linux (chflags doesn't exist) and harmless if already clear.
      chflags nohidden "$OUT" 2>/dev/null || true
      (( _REPLACING_SOURCE )) && note "Original source file has been replaced."
      (( CHECKSUM )) && write_checksum "$OUT"
      note "Build SUCCEEDED."
    fi

    _print_completed_steps

    if [[ -n "$WORKDIR" && -d "$WORKDIR" && "${DEBUG:-0}" != "1" && $KEEP_TEMP_ALWAYS -eq 0 ]]; then
      (( KEEP_TEMP )) && note "--keep-temp preserves workdir on failure only; use -K/--keep-temp-always to keep on success."
      # Safety: only remove if path matches expected .muxm.tmp. pattern
      if [[ "$WORKDIR" == *"/.muxm.tmp."* ]]; then
        rm -rf "$WORKDIR"
      else
        warn "Refusing to remove unexpected workdir path: $WORKDIR"
      fi
    else
      note "Keeping workdir: $WORKDIR"
    fi
    exit 0
  else
    [[ -z "$FAIL_MSG" ]] && FAIL_MSG="No output produced (likely earlier parse/runtime error)."
    printf "❌ Build FAILED. %s\n" "$FAIL_MSG"
    
    _print_completed_steps
    echo "See log: $LOGFILE"

    # Clean up temp output file on failure
    [[ -f "$TMP_OUT" ]] && rm -f "$TMP_OUT"

    if [[ -n "$WORKDIR" && -d "$WORKDIR" && "${DEBUG:-0}" != "1" && $KEEP_TEMP -eq 0 && $KEEP_TEMP_ALWAYS -eq 0 ]]; then
      # Safety: only remove if path matches expected .muxm.tmp. pattern
      if [[ "$WORKDIR" == *"/.muxm.tmp."* ]]; then
        rm -rf "$WORKDIR"
      else
        warn "Refusing to remove unexpected workdir path: $WORKDIR"
      fi
    else
      note "Keeping failure artifacts at: $WORKDIR"
    fi
    exit "${EXIT_CODE:-1}"
  fi
}
trap 'on_exit' EXIT

# ===== Section 19: Disk space preflight =======================================================
disk_free_warn() {
