# ===== Section 5: Basic helpers ===============================================================
# ---- Logging helpers ----
# All output goes to stderr to keep stdout clean for piping.
# say()  — plain informational message (no prefix)
# note() — informational with ℹ️  prefix
# warn() — warning with ⚠️  prefix
# die()  — fatal error with ❌ prefix; exits with code (default 1)
#           Usage: die "message" or die <code> "message"
say()  { printf "%s\n" "$@" >&2; }
note() { printf "ℹ️  %s\n" "$@" >&2; }
warn() { printf "⚠️  %s\n" "$@" >&2; }

# Lowercase a string (avoids repeated inline tr calls)
_lower(){ printf '%s' "$1" | tr '[:upper:]' '[:lower:]'; }

die()  {
  local code=1
  if [[ $# -gt 1 && "$1" =~ ^[0-9]+$ ]]; then code="$1"; shift; fi
  FAILED=1; EXIT_CODE="$code"; FAIL_MSG="Fatal: $*"
  printf "❌ ERROR: %s\n" "$FAIL_MSG" >&2
  exit "$code"
}

on_error(){
  local lineno="$1" cmd="$2" status="$3"
  FAILED=1
  EXIT_CODE="${EXIT_CODE:-$status}"
  FAIL_MSG="Command failed at line $lineno: $cmd (exit $status)"
  printf "❌ ERROR: %s\n" "$FAIL_MSG" >&2
}

mark_done(){ COMPLETED_STEPS+=("$1"); }

need(){
  command -v "$1" >/dev/null 2>&1 || die 10 "Missing required tool: $1"
}

# Improved realpath that handles non-existent files on all platforms
realpath_fallback(){
  local p="$1"
  
  # Try GNU realpath with -m (allows missing files)
  if command -v realpath >/dev/null 2>&1; then
    if realpath -m "$p" 2>/dev/null; then
      return 0
    fi
  fi
  
  # Fallback for macOS/BSD and systems without realpath
  local dir base
  dir="$(dirname -- "$p")"
  base="$(basename -- "$p")"
  
  if [[ -d "$dir" ]]; then
    echo "$(cd "$dir" 2>/dev/null && pwd)/$base"
  elif [[ "$p" =~ ^/ ]]; then
    # Already absolute
    echo "$p"
  else
    # Make absolute from current directory
    echo "$PWD/$p"
  fi
}

# Improved filesize_pretty - checks native stat first for performance
filesize_pretty(){
  local file="$1"
  # Try native stat first (faster)
  if stat -f "%N %z bytes" /dev/null >/dev/null 2>&1; then
    # macOS/BSD
    stat -f "%N %z bytes" "$file"
  elif stat --printf '%n %s bytes\n' /dev/null >/dev/null 2>&1; then
    # GNU/Linux
    stat --printf '%n %s bytes\n' "$file"
  elif command -v gstat >/dev/null 2>/dev/null; then
    # GNU stat as gstat
    gstat -c "%n %s bytes" "$file"
  else
    ls -lh "$file"
  fi
}

write_checksum(){
  local p="$1"
  local -a cmd=()
  if command -v sha256sum >/dev/null 2>&1; then
    cmd=(sha256sum)
  elif command -v shasum >/dev/null 2>&1; then
    cmd=(shasum -a 256)
  else
    warn "Checksum tool not found"; return 0
  fi
  note "Writing checksum → ${p}.sha256"
  "${cmd[@]}" "$p" > "${p}.sha256"
}

# Validate that a media file exists, is non-empty, and is parseable by ffprobe.
# Args: $1 — file path, $2 — context label for error message
# Dies on failure.
_validate_media_file(){
  local file="$1" label="${2:-output}"
  [[ -s "$file" ]] || die 41 "$label produced empty file"
  ffprobe -v error "$file" >/dev/null 2>&1 || die 41 "$label produced corrupt file"
}

ffmpeg_has_muxer(){
  local mux="$1"
  ffmpeg -hide_banner -muxers 2>/dev/null | awk '{print $1}' | grep -qx "$mux"
}

# ===== Section 6: Config chain: Defaults → /etc → ~ → project =================================
_muxm_try_source(){
  local f="$1"
  [[ -r "$f" ]] || return 0
  # shellcheck disable=SC1090
  . "$f"
  MUXM_CONFIG_LOADED+=("$f")
}
_muxm_try_source /etc/.muxmrc
_muxm_try_source "$HOME/.muxmrc"
_muxm_try_source "./.muxmrc"

# ===== Section 6b: Profile pre-scan & application ==============================================
# Two-pass CLI: first extract --profile, apply it, then let full CLI parse override.
#
# Precedence for PROFILE_NAME:
#   1. /etc/.muxmrc, ~/.muxmrc, ./.muxmrc  — may set PROFILE_NAME (lowest)
#   2. CLI --profile <n>                    — overrides config-file value (highest)
#
# Users can set a default profile in any .muxmrc file:
#   PROFILE_NAME="atv-directplay-hq"
# CLI --profile always overrides a config-file PROFILE_NAME.

# Track where the profile originated (for diagnostics / conflict warnings)
_PROFILE_SOURCE=""
if [[ -n "${PROFILE_NAME:-}" ]]; then
  _PROFILE_SOURCE="config-file"
fi

# Pre-scan: walk args looking only for --profile <n>
_prescan_args=("$@")
_filtered_args=()
_i=0
while (( _i < ${#_prescan_args[@]} )); do
  if [[ "${_prescan_args[$_i]}" == "--profile" ]]; then
    if (( _i + 1 < ${#_prescan_args[@]} )); then
      PROFILE_NAME="${_prescan_args[$((_i+1))]}"
      _PROFILE_SOURCE="cli"
      _i=$((_i + 2))
    else
      die 11 "--profile requires a profile name (dv-archival, hdr10-hq, atv-directplay-hq, universal)"
    fi
  else
    _filtered_args+=("${_prescan_args[$_i]}")
    _i=$((_i + 1))
  fi
done
# Replace positional parameters with filtered args (--profile consumed)
set -- "${_filtered_args[@]}"
unset _prescan_args _filtered_args _i

# ---- Profile application functions (pure assignment, no side effects) ----

apply_profile_dv_archival() {
  # Goal: Preserve DV + HDR10 metadata, lossless audio, lossless remux only.
  DISABLE_DV=0
  ALLOW_DV_FALLBACK=1
  DV_CONVERT_TO_P81_IF_FAIL=1
  # Container: auto (keep source extension; default to mkv for broad codec support)
  OUTPUT_EXT="mkv"
  # Video: copy, don't re-encode
  VIDEO_COPY_IF_COMPLIANT=1
  VIDEO_CODEC="libx265"
  # Audio: lossless passthrough, no stereo fallback by default
  AUDIO_LOSSLESS_PASSTHROUGH=1
  ADD_STEREO_IF_MULTICH=0
  # Subs: keep all; no burn
  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=1
  SUB_BURN_FORCED=0
  SUB_EXPORT_EXTERNAL=0
  # Chapters/metadata: keep
  KEEP_CHAPTERS=1
  STRIP_METADATA=0
  # Skip-if-ideal: on
  SKIP_IF_IDEAL=1
  # Reporting: JSON
  REPORT_JSON=1
}

apply_profile_hdr10_hq() {
  # Goal: Max HDR10 quality, strip DV, preserve lossless audio + stereo fallback.
  DISABLE_DV=1
  ALLOW_DV_FALLBACK=0
  DV_CONVERT_TO_P81_IF_FAIL=0
  # Container: mkv
  OUTPUT_EXT="mkv"
  # Video: HEVC re-encode with high-quality HDR10 params
  VIDEO_CODEC="libx265"
  VIDEO_COPY_IF_COMPLIANT=0
  CRF_VALUE=17
  PRESET_VALUE="slow"
  X265_PARAMS_BASE='profile=main10:repeat-headers=1:hdr-opt=1:hdr10=1:hdr10-opt=1:colorprim=bt2020:transfer=smpte2084:colormatrix=bt2020nc:range=limited:aq-mode=3:aq-strength=1.3:psy-rd=2.0:psy-rdoq=1.0:rc-lookahead=60'
  HDR_TARGET_PIXFMT="yuv420p10le"
  FORCE_CHROMA_420=1
  # Audio: lossless passthrough + stereo fallback
  AUDIO_LOSSLESS_PASSTHROUGH=1
  ADD_STEREO_IF_MULTICH=1
  STEREO_BITRATE="256k"
  # Subs: keep all; no burn
  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=1
  SUB_BURN_FORCED=0
  # Chapters/metadata: keep
  KEEP_CHAPTERS=1
  STRIP_METADATA=0
}

apply_profile_atv_directplay_hq() {
  # Goal: Conform to Apple TV/Plex Direct Play constraints while keeping high quality.
  DISABLE_DV=0
  ALLOW_DV_FALLBACK=1
  DV_CONVERT_TO_P81_IF_FAIL=1
  # Container: mp4 for ATV Direct Play
  OUTPUT_EXT="mp4"
  # Video: prefer copy if compliant; else HEVC Main10
  VIDEO_CODEC="libx265"
  VIDEO_COPY_IF_COMPLIANT=1
  CRF_VALUE=17
  PRESET_VALUE="slow"
  X265_PARAMS_BASE='profile=main10:repeat-headers=1:hdr-opt=1:aq-mode=3:aq-strength=1.3:psy-rd=2.0:psy-rdoq=1.0:rc-lookahead=60'
  HDR_TARGET_PIXFMT="yuv420p10le"
  FORCE_CHROMA_420=1
  # Audio: E-AC-3 for surround (ATV can't Direct Play TrueHD), AAC stereo fallback
  AUDIO_LOSSLESS_PASSTHROUGH=0
  ADD_STEREO_IF_MULTICH=1
  STEREO_BITRATE="256k"
  EAC3_BITRATE_5_1="640k"
  EAC3_BITRATE_7_1="768k"
  # Subs: burn forced (or mov_text); keep others as mov_text
  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=1
  SUB_BURN_FORCED=1
  SUB_EXPORT_EXTERNAL=0
  # Chapters/metadata: keep
  KEEP_CHAPTERS=1
  STRIP_METADATA=0
  # Skip-if-ideal: on
  SKIP_IF_IDEAL=1
}

apply_profile_universal() {
  # Goal: Compatibility over fidelity. SDR H.264, AAC stereo, burn forced subs.
  DISABLE_DV=1
  ALLOW_DV_FALLBACK=0
  DV_CONVERT_TO_P81_IF_FAIL=0
  # Container: mp4
  OUTPUT_EXT="mp4"
  # Video: H.264 SDR, tone-map HDR if present
  VIDEO_CODEC="libx264"
  VIDEO_COPY_IF_COMPLIANT=0
  TONEMAP_HDR_TO_SDR=1
  CRF_VALUE=18
  PRESET_VALUE="slow"
  FORCE_CHROMA_420=1
  # Audio: AAC stereo forced; optional AC3 5.1
  AUDIO_FORCE_CODEC="aac"
  AUDIO_LOSSLESS_PASSTHROUGH=0
  ADD_STEREO_IF_MULTICH=0
  MAX_AUDIO_CHANNELS=2
  STEREO_BITRATE="256k"
  # Subs: burn forced; export others as external SRT
  SUB_INCLUDE_FORCED=1
  SUB_INCLUDE_FULL=1
  SUB_INCLUDE_SDH=0
  SUB_BURN_FORCED=1
  SUB_EXPORT_EXTERNAL=1
  # Chapters/metadata: strip
  KEEP_CHAPTERS=0
  STRIP_METADATA=1
}

# Dispatcher
apply_profile() {
  [[ -z "${PROFILE_NAME:-}" ]] && return 0
  case "$PROFILE_NAME" in
    dv-archival)         apply_profile_dv_archival ;;
    hdr10-hq)            apply_profile_hdr10_hq ;;
    atv-directplay-hq)   apply_profile_atv_directplay_hq ;;
    universal)           apply_profile_universal ;;
    *)
      printf "❌ ERROR: Unknown profile: %s\n" "$PROFILE_NAME" >&2
      printf "   Valid profiles: dv-archival, hdr10-hq, atv-directplay-hq, universal\n" >&2
      exit 11
      ;;
  esac
  note "Applied profile: $PROFILE_NAME (source: ${_PROFILE_SOURCE:-unknown})"
}

# Apply profile now (after config files, before CLI flags)
apply_profile

