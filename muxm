# Portable sed in-place: macOS sed requires '' after -i, GNU sed does not.
_sed_inplace(){
  if sed --version 2>/dev/null | grep -q GNU; then
    sed -i "$@"
  else
    sed -i '' "$@"
  fi
}

# shellcheck disable=SC2016  # $HOME must expand at shell-startup, not install-time
_completions_source_line='source "$HOME/.muxm/muxm-completion.bash"'
_completions_marker='# muxm tab completion'

_install_completions(){
  local comp_dir="$HOME/.muxm"
  local comp_file="$comp_dir/muxm-completion.bash"

  say "=== ${APP_NAME} v${VERSION} — Completion Installer ==="
  echo ""

  # Create directory (handle stale file from earlier installs)
  if [[ -e "$comp_dir" && ! -d "$comp_dir" ]]; then
    printf '  ⚠️  %s exists as a file — replacing with directory\n' "$comp_dir"
    rm -f "$comp_dir"
  fi
  if [[ ! -d "$comp_dir" ]]; then
    printf '  📁 Creating %s\n' "$comp_dir"
    mkdir -p "$comp_dir"
  fi

  # Write completion script
  _completions_emit > "$comp_file"
  chmod +x "$comp_file"
  printf '  ✅ Wrote %s\n' "$comp_file"
  echo ""

  # Detect and patch shell RC files
  local -a rc_files=()
  # Bash: prefer ~/.bash_profile on macOS (login shell), ~/.bashrc on Linux
  [[ -f "$HOME/.bash_profile" ]] && rc_files+=("$HOME/.bash_profile")
  [[ -f "$HOME/.bashrc" ]]       && rc_files+=("$HOME/.bashrc")
  [[ -f "$HOME/.zshrc" ]]        && rc_files+=("$HOME/.zshrc")

  if [[ ${#rc_files[@]} -eq 0 ]]; then
    printf '  ⚠️  No shell RC files found (~/.bashrc, ~/.bash_profile, ~/.zshrc).\n'
    printf '     Add this line manually to your shell config:\n\n'
    printf '       %s\n' "$_completions_marker"
    printf '       %s\n\n' "$_completions_source_line"
  else
    local patched=0
    for rc in "${rc_files[@]}"; do
      local rc_base="${rc##*/}"
      printf '  %-20s' "$rc_base"
      if grep -qF 'muxm-completion.bash' "$rc" 2>/dev/null; then
        printf '✅ already configured\n'
      else
        # Ensure file ends with a newline before appending
        [[ -s "$rc" ]] && [[ "$(tail -c 1 "$rc")" != "" ]] && printf '\n' >> "$rc"
        printf '\n%s\n%s\n' "$_completions_marker" "$_completions_source_line" >> "$rc"
        printf '✅ added source line\n'
        patched=$(( patched + 1 ))
      fi
    done

    echo ""
    if (( patched > 0 )); then
      printf '  Restart your shell or run:\n'
      printf '    source %s\n' "$comp_file"
    else
      printf '  All shell configs already have muxm completions.\n'
    fi
  fi

  exit 0
}

_uninstall_completions(){
  local comp_dir="$HOME/.muxm"
  local comp_file="$comp_dir/muxm-completion.bash"

  say "=== ${APP_NAME} v${VERSION} — Completion Uninstaller ==="
  echo ""

  # Remove completion file
  if [[ -f "$comp_file" ]]; then
    rm -f "$comp_file"
    printf '  ✅ Removed %s\n' "$comp_file"
  else
    printf '  ⚠️  Completion file not found at %s\n' "$comp_file"
  fi

  # Clean source lines from RC files
  local -a rc_files=("$HOME/.bash_profile" "$HOME/.bashrc" "$HOME/.zshrc")
  for rc in "${rc_files[@]}"; do
    [[ -f "$rc" ]] || continue
    local rc_base="${rc##*/}"
    if grep -qF 'muxm-completion.bash' "$rc" 2>/dev/null; then
      # Remove the marker comment and source line
      _sed_inplace '/# muxm tab completion/d' "$rc"
      _sed_inplace '/muxm-completion\.bash/d' "$rc"
      printf '  ✅ Cleaned %s\n' "$rc_base"
    fi
  done

  # Remove directory if empty
  if [[ -d "$comp_dir" ]] && [[ -z "$(ls -A "$comp_dir" 2>/dev/null)" ]]; then
    rmdir "$comp_dir"
    printf '  ✅ Removed empty %s\n' "$comp_dir"
  fi

  echo ""
  printf '  Restart your shell to complete removal.\n'
  exit 0
}

# Pre-scan for --install-completions / --uninstall-completions
for _arg in "$@"; do
  case "$_arg" in
    --install-completions)   _install_completions ;;
    --uninstall-completions) _uninstall_completions ;;
  esac
done
