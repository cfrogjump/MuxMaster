# Improved realpath that handles non-existent files on all platforms
realpath_fallback(){
  local p="$1"
  
  # Try GNU realpath with -m (allows missing files)
  if command -v realpath >/dev/null 2>&1; then
    if realpath -m "$p" 2>/dev/null; then
      return 0
    fi
  fi
  
  # Fallback for macOS/BSD and systems without realpath
  local dir base
  dir="$(dirname -- "$p")"
  base="$(basename -- "$p")"
  
  if [[ -d "$dir" ]]; then
    echo "$(cd "$dir" 2>/dev/null && pwd)/$base"
  elif [[ "$p" =~ ^/ ]]; then
    # Already absolute
    echo "$p"
  else
    # Make absolute from current directory
    echo "$PWD/$p"
  fi
}

# Improved filesize_pretty - outputs human-readable file size string to stdout.
# Composable: callers format/route the output (e.g., say "Size: $(filesize_pretty f)")
filesize_pretty(){
  local file="$1" bytes=""
  [[ -f "$file" ]] || { echo "unknown (file not found)"; return 1; }

  # Get raw byte count (try multiple methods for portability)
  if stat -f "%z" "$file" >/dev/null 2>&1; then
    bytes="$(stat -f "%z" "$file")"            # macOS / BSD
  elif stat -c "%s" "$file" >/dev/null 2>&1; then
    bytes="$(stat -c "%s" "$file")"            # GNU / Linux
  elif command -v gstat >/dev/null 2>&1; then
    bytes="$(gstat -c "%s" "$file")"           # Homebrew GNU stat
  elif command -v wc >/dev/null 2>&1; then
    bytes="$(wc -c < "$file" | tr -d ' ')"     # POSIX fallback
  fi

  if [[ -z "$bytes" || ! "$bytes" =~ ^[0-9]+$ ]]; then
    echo "unknown size"
    return 0
  fi

  # Human-readable formatting
  if (( bytes >= 1073741824 )); then
    printf '%.2f GB (%s bytes)\n' "$(echo "scale=2; $bytes/1073741824" | bc)" "$bytes"
  elif (( bytes >= 1048576 )); then
    printf '%.1f MB (%s bytes)\n' "$(echo "scale=1; $bytes/1048576" | bc)" "$bytes"
  elif (( bytes >= 1024 )); then
    printf '%.0f KB\n' "$(echo "scale=0; $bytes/1024" | bc)"
  else
    printf '%s bytes\n' "$bytes"
  fi
}

write_checksum(){
  local p="$1"
  local -a cmd=()
  if command -v sha256sum >/dev/null 2>&1; then
    cmd=(sha256sum)
  elif command -v shasum >/dev/null 2>&1; then
    cmd=(shasum -a 256)
  else
    warn "Checksum tool not found"; return 0
  fi
  note "Writing checksum → ${p}.sha256"
  "${cmd[@]}" "$p" > "${p}.sha256"
}

# Validate that a media file exists, is non-empty, and is parseable by ffprobe.
# Args: $1 — file path, $2 — context label for error message
# Dies on failure.
_validate_media_file(){
  local file="$1" label="${2:-output}"
  [[ -s "$file" ]] || die 41 "$label produced empty file"
  ffprobe -v error "$file" >/dev/null 2>&1 || die 41 "$label produced corrupt file"
}

ffmpeg_has_muxer(){
  local mux="$1"
  ffmpeg -hide_banner -muxers 2>/dev/null | awk '{print $1}' | grep -qx "$mux"
}

# ===== Section 5b: Dependency installer ========================================================
# Invoked via --install-dependencies. Checks for all tools required by muxm and
# installs any that are missing via Homebrew and pipx. Exits after completion.
#
# Required:     ffmpeg, ffprobe, jq
# DV pipeline:  dovi_tool, mp4box (gpac)
# Subtitles:    tesseract, pgsrip (Python, via pipx)
#
# Config chain is sourced first (Section 6 below) so the installer sees the
# user's resolved SUB_OCR_TOOL and other config-file settings.

# ===== Section 6: Config chain: Defaults → /etc → ~ → project =================================
_muxm_try_source(){
  local f="$1"
  [[ -r "$f" ]] || return 0
  # shellcheck disable=SC1090
  . "$f"
  MUXM_CONFIG_LOADED+=("$f")
}
_muxm_try_source /etc/.muxmrc
_muxm_try_source "$HOME/.muxmrc"
_muxm_try_source "./.muxmrc"

_dep_install_dependencies(){
  say "=== ${APP_NAME} v${VERSION} — Dependency Installer ==="
  echo ""

  # ---- Preflight: need Homebrew and a working shell
  if ! command -v brew >/dev/null 2>&1; then
    printf "❌ Homebrew is not installed. Install it first:\n" >&2
    printf "   /bin/bash -c \"\$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\"\n" >&2
    exit 10
  fi

  local -i total=0 installed=0 skipped=0 failed=0

  # Helper: check + brew install
  _brew_ensure(){
    local _tool="$1" formula="${2:-$1}"
    total=$(( total + 1 ))
    printf "  %-14s" "$_tool"
    if command -v "$_tool" >/dev/null 2>&1; then
      printf "✅ already installed (%s)\n" "$(command -v "$_tool")"
      skipped=$(( skipped + 1 ))
    else
      printf "⏳ installing via brew (%s)...\n" "$formula"
      if brew install "$formula" 2>&1 | sed 's/^/    /'; then
        if command -v "$_tool" >/dev/null 2>&1; then
          printf "  %-14s✅ installed successfully\n" "$_tool"
          installed=$(( installed + 1 ))
        else
          printf "  %-14s⚠️  brew install succeeded but '%s' not found in PATH\n" "$_tool" "$_tool"
          failed=$(( failed + 1 ))
        fi
      else
        printf "  %-14s❌ brew install failed\n" "$_tool"
        failed=$(( failed + 1 ))
      fi
    fi
  }

  # Helper: check + pipx install (for Python CLI tools)
  _pipx_ensure(){
    local _tool="$1" pkg="${2:-$1}"
    total=$(( total + 1 ))
    printf "  %-14s" "$_tool"
    if command -v "$_tool" >/dev/null 2>&1; then
      printf "✅ already installed (%s)\n" "$(command -v "$_tool")"
      skipped=$(( skipped + 1 ))
    else
      # Ensure pipx is available
      if ! command -v pipx >/dev/null 2>&1; then
        printf "⏳ installing pipx first...\n"
        brew install pipx 2>&1 | sed 's/^/    /'
        pipx ensurepath 2>/dev/null || true
        # Re-source PATH so pipx-installed tools are visible
        eval "$(pipx environment --value PIPX_BIN_DIR 2>/dev/null)" 2>/dev/null || true
        export PATH="$HOME/.local/bin:$PATH"
      fi
      printf "  %-14s⏳ installing via pipx (%s)...\n" "$_tool" "$pkg"
      if pipx install "$pkg" 2>&1 | sed 's/^/    /'; then
        export PATH="$HOME/.local/bin:$PATH"
        if command -v "$_tool" >/dev/null 2>&1; then
          printf "  %-14s✅ installed successfully\n" "$_tool"
          installed=$(( installed + 1 ))
        else
          printf "  %-14s⚠️  pipx install succeeded but '%s' not found in PATH\n" "$_tool" "$_tool"
          printf "              Try: pipx ensurepath && source ~/.zshrc\n"
          failed=$(( failed + 1 ))
        fi
      else
        printf "  %-14s❌ pipx install failed\n" "$_tool"
        failed=$(( failed + 1 ))
      fi
    fi
  }

  # Helper: check for Tesseract language data
  _tessdata_ensure(){
    local lang="$1"
    total=$(( total + 1 ))
    printf "  %-14s" "tess:$lang"
    local tessdir
    tessdir="$(brew --prefix 2>/dev/null)/share/tessdata"
    if [[ -f "$tessdir/${lang}.traineddata" ]]; then
      printf "✅ language data present (%s)\n" "$tessdir/${lang}.traineddata"
      skipped=$(( skipped + 1 ))
    else
      printf "⏳ installing tesseract-lang for full language support...\n"
      if brew install tesseract-lang 2>&1 | sed 's/^/    /'; then
        if [[ -f "$tessdir/${lang}.traineddata" ]]; then
          printf "  %-14s✅ language data installed\n" "tess:$lang"
          installed=$(( installed + 1 ))
        else
          printf "  %-14s⚠️  installed but %s.traineddata not found in %s\n" "tess:$lang" "$lang" "$tessdir"
          failed=$(( failed + 1 ))
        fi
      else
        printf "  %-14s❌ brew install tesseract-lang failed\n" "tess:$lang"
        failed=$(( failed + 1 ))
      fi
    fi
  }

  say "Core tools (required):"
  _brew_ensure ffmpeg   ffmpeg
  _brew_ensure ffprobe  ffmpeg
  _brew_ensure jq       jq
  echo ""

  say "Dolby Vision pipeline (recommended):"
  _brew_ensure dovi_tool dovi_tool
  # mp4box: binary name varies — check both MP4Box and mp4box
  total=$(( total + 1 ))
  printf "  %-14s" "mp4box"
  if command -v MP4Box >/dev/null 2>&1 || command -v mp4box >/dev/null 2>&1; then
    local _mp4box_path
    _mp4box_path="$(command -v MP4Box 2>/dev/null || command -v mp4box 2>/dev/null)"
    printf "✅ already installed (%s)\n" "$_mp4box_path"
    skipped=$(( skipped + 1 ))
  else
    printf "⏳ installing via brew (gpac)...\n"
    if brew install gpac 2>&1 | sed 's/^/    /'; then
      if command -v MP4Box >/dev/null 2>&1 || command -v mp4box >/dev/null 2>&1; then
        printf "  %-14s✅ installed successfully\n" "mp4box"
        installed=$(( installed + 1 ))
      else
        printf "  %-14s⚠️  brew install succeeded but mp4box/MP4Box not found in PATH\n" "mp4box"
        failed=$(( failed + 1 ))
      fi
    else
      printf "  %-14s❌ brew install gpac failed\n" "mp4box"
      failed=$(( failed + 1 ))
    fi
  fi
  echo ""

  say "Subtitle OCR pipeline (recommended for PGS/Blu-ray subtitles):"
  _brew_ensure tesseract tesseract
  _tessdata_ensure eng
  _pipx_ensure pgsrip   pgsrip
  echo ""

  # TESSDATA_PREFIX check
  say "Environment:"
  local tessdir_resolved
  tessdir_resolved="$(brew --prefix 2>/dev/null)/share/tessdata"
  printf "  %-14s" "TESSDATA"
  if [[ -n "${TESSDATA_PREFIX:-}" ]]; then
    printf "✅ TESSDATA_PREFIX=%s\n" "$TESSDATA_PREFIX"
  elif [[ -d "$tessdir_resolved" ]]; then
    printf "⚠️  TESSDATA_PREFIX not set. Add to ~/.zshrc:\n"
    printf "              export TESSDATA_PREFIX=\"%s\"\n" "$tessdir_resolved"
  else
    printf "⚠️  No tessdata directory found\n"
  fi

  # .muxmrc OCR tool configuration check
  printf "  %-14s" "OCR config"
  if command -v pgsrip >/dev/null 2>&1; then
    if [[ "${SUB_OCR_TOOL:-sub2srt}" == "sub2srt" ]]; then
      printf "⚠️  pgsrip is installed but SUB_OCR_TOOL is '%s'.\n" "${SUB_OCR_TOOL:-sub2srt}"
      printf "              Set in ~/.muxmrc:  SUB_OCR_TOOL=\"pgsrip\"\n"
      printf "              Or use per-run:    --ocr-tool pgsrip\n"
    else
      printf "✅ SUB_OCR_TOOL=%s\n" "$SUB_OCR_TOOL"
    fi
  else
    printf "ℹ️  SUB_OCR_TOOL=%s (pgsrip not installed)\n" "${SUB_OCR_TOOL:-sub2srt}"
  fi
  echo ""

  # Summary
  say "Summary: $total checked, $installed installed, $skipped already present, $failed failed"
  if (( failed > 0 )); then
    warn "Some dependencies could not be installed. Check output above for details."
    exit 1
  fi
  say "✅ All dependencies satisfied."
  exit 0
}

# Pre-scan for --install-dependencies (must run before config/profile/CLI parsing)
for _arg in "$@"; do
  if [[ "$_arg" == "--install-dependencies" ]]; then
    _dep_install_dependencies
    # _dep_install_dependencies always exits; this line is unreachable
  fi
done
unset _arg

# ===== Section 5b½: Man page installer (--install-man / --uninstall-man) =======================
# Embedded man page content, installed to the system man1 directory.
# Detects Homebrew prefix on macOS (Apple Silicon vs Intel) and falls back to
# /usr/local/share/man/man1. Uses sudo if the target directory isn't writable.

_man_target_dir(){
  # Prefer Homebrew man path if brew is installed
  if command -v brew >/dev/null 2>&1; then
    echo "$(brew --prefix)/share/man/man1"
  else
    echo "/usr/local/share/man/man1"
  fi
}

_man_emit(){
  cat <<'MANPAGE_EOF'
.TH MUXM 1 "2026-02-23" "MuxMaster v0.12.0" "User Commands"
.SH NAME
muxm \- Universal DV/HLG/HDR10/SDR video encoder/muxer with format profiles
