# ================================================================
#  MuxMaster .muxmrc — configuration file
#  Generated by: muxm --create-config
#  Precedence: Script defaults → /etc/.muxmrc → ~/.muxmrc → ./.muxmrc → CLI flags
#  Tip: Uncomment a line to override. Keep values shell-safe.
# ================================================================
# Profile: atv-directplay-hq
# Generated: 2026-02-26 15:31:25
#
# Variables set by this profile are uncommented below.
# All other variables are commented with their defaults — uncomment to customize.

# =========================
# Profile (format presets)
# =========================

# Default profile to apply. CLI --profile overrides this value.
# Valid profiles: dv-archival, hdr10-hq, atv-directplay-hq, streaming, animation, universal
# Profiles set many variables at once; CLI flags still override individual values.
PROFILE_NAME="atv-directplay-hq"


# =========================
# Video (x265/x264) fundamentals
# =========================

# Video encoder: libx265 (default, HEVC) or libx264 (H.264, universal compat)
VIDEO_CODEC=libx265

# CRF (Constant Rate Factor): 0–51 (lower = higher quality, larger files)
#   14–18: visually transparent  |  19–22: good balance  |  23–28: smaller files
CRF_VALUE=17

# Preset: speed/efficiency trade-off (faster → bigger files, slower → smaller)
# Options: ultrafast, superfast, veryfast, faster, fast, medium, slow, slower, veryslow, placebo
PRESET_VALUE=slower

# Base x265 params: advanced tuning as a single string
# Keep values colon-separated. Override entirely if you know what you're doing.
X265_PARAMS_BASE='profile=main10:repeat-headers=1:hdr-opt=1:hdr10=1:hdr10-opt=1:aq-mode=3:aq-strength=1.3:psy-rd=2.0:psy-rdoq=1.0:rc-lookahead=60'

# Level/IDR constraint for compatibility (e.g., 5.1). Leave empty to let encoder decide.
#LEVEL_VALUE=5.1

# Conservative VBV guardrails (apply when LEVEL_VALUE is set)
#   1 = apply cautious vbv-maxrate/bufsize  |  0 = don't apply additional limits
#CONSERVATIVE_VBV=1

# Skip encode if source video already matches profile requirements
#   1 = copy video stream if compliant (much faster)  |  0 = always re-encode
VIDEO_COPY_IF_COMPLIANT=1


# =========================
# Pixel format / Chroma
# =========================

# Force chroma subsampling 4:2:0 (most Direct Play targets require 4:2:0)
#   1 = downsample 4:2:2/4:4:4 → 4:2:0  |  0 = keep source chroma
FORCE_CHROMA_420=1

# SDR 10-bit policy: 1 = keep 10-bit if source is 10-bit SDR  |  0 = force 8-bit
#SDR_USE_10BIT_IF_SRC_10BIT=1

# Target pixel format when HDR (HLG/HDR10/DV base) is detected
HDR_TARGET_PIXFMT=yuv420p10le


# =========================
# Tone-mapping (HDR → SDR)
# =========================

# Tone-map HDR to SDR (used by the universal profile for max compatibility)
#   1 = convert HDR/HLG sources to SDR  |  0 = preserve HDR (default)
#TONEMAP_HDR_TO_SDR=0

# Tone-map filter chain: advanced ffmpeg filter string for HDR→SDR conversion.
#TONEMAP_FILTER='zscale=t=linear:npl=100,format=gbrpf32le,zscale=p=bt709,tonemap=tonemap=hable:desat=0,zscale=t=bt709:m=bt709:r=tv,format=yuv420p'


# =========================
# Threads / parallelism
# =========================

# Threads for ffmpeg (empty = let ffmpeg decide)
#THREADS=


# =========================
# Dolby Vision handling
# =========================

# Disable DV handling entirely: 1 = ignore DV  |  0 = detect and process DV
DISABLE_DV=0

# Allow fallback if DV injection/conversion fails: 1 = continue  |  0 = fatal
ALLOW_DV_FALLBACK=1

# Try converting Profile 7 RPU → Profile 8.1 if direct inject fails
DV_CONVERT_TO_P81_IF_FAIL=1


# =========================
# Audio selection strategy
# =========================

# Language preference list (comma-separated)
#AUDIO_LANG_PREF=eng

# Codec preference order (leftmost best)
#AUDIO_CODEC_PREFERENCE=eac3,ac3,aac,alac,other

# Force a specific audio track by index (0-based). Leave empty for auto.
#AUDIO_TRACK_OVERRIDE=

# Scoring weights (advanced):
#   Language bonus is weighted higher than channel count because selecting
#   the wrong language is a worse outcome than fewer channels.
#   Reduce AUDIO_SCORE_LANG_BONUS to ~25 if you always want the highest-
#   channel track regardless of language.
#AUDIO_SCORE_CHANNEL_MULTIPLIER=20
#AUDIO_SCORE_SURROUND_BONUS=30
#AUDIO_SCORE_LANG_BONUS=150

# Penalty applied to commentary / audio-description tracks (detected by title tag).
# Set to 0 to disable commentary detection.
#AUDIO_SCORE_COMMENTARY_PENALTY=200


# =========================
# Audio transcode policy
# =========================

# Stereo AAC bitrate (when transcoding or creating a fallback)
STEREO_BITRATE=256k

# Maximum output channels (caps E-AC-3 downmix target)
#   6 = 5.1, 8 = 7.1
#MAX_AUDIO_CHANNELS=8

# Add a stereo AAC fallback track when primary >2ch
ADD_STEREO_IF_MULTICH=1

# E-AC-3 bitrates for multichannel transcode
EAC3_BITRATE_5_1=640k
EAC3_BITRATE_7_1=768k

# Force all audio to a specific codec (e.g., "aac" for universal playback)
#AUDIO_FORCE_CODEC=

# Allow lossless audio codecs (TrueHD, DTS-HD MA, FLAC) to pass through
#   1 = copy lossless  |  0 = transcode to lossy
AUDIO_LOSSLESS_PASSTHROUGH=0

# Run stereo and primary audio jobs in parallel
#PARALLEL_AUDIO=0


# =========================
# Subtitles
# =========================

# Language preference for subtitle track selection (comma-separated)
#SUB_LANG_PREF=eng

# Include forced subtitles (foreign dialogue, signs)
SUB_INCLUDE_FORCED=1

# Include full (non-forced) subtitle tracks
SUB_INCLUDE_FULL=1

# Include SDH/HI (subtitles for the deaf and hard of hearing)
SUB_INCLUDE_SDH=1

# Maximum subtitle tracks to include in output
#SUB_MAX_TRACKS=3

# Burn forced subtitles into the video stream (hardcoded, cannot be turned off)
SUB_BURN_FORCED=1

# Export non-forced subtitles as external .srt files alongside output
SUB_EXPORT_EXTERNAL=0

# Enable OCR for bitmap subtitles (PGS/VobSub → SRT)
# MP4 cannot carry PGS bitmaps; OCR converts them to text-based SRT.
#   1 = attempt OCR  |  0 = drop bitmap subtitles that can't be embedded
SUB_ENABLE_OCR=1

# OCR tool for bitmap → text subtitle conversion
# Supported: "sub2srt", "pgsrip"
# pgsrip requires: pgsrip (pipx) + tesseract. Install via --install-dependencies.
# Auto-detected: pgsrip found on this machine at config-generation time.
SUB_OCR_TOOL=pgsrip

# OCR language for Tesseract (ISO 639-3, e.g., eng, fra, deu)
#SUB_OCR_LANG=eng


# =========================
# Mux / output container
# =========================

# Output extension: mp4|m4v|mov|mkv
OUTPUT_EXT=mp4

# Keep chapter markers in output
KEEP_CHAPTERS=1

# Strip non-essential metadata from output
STRIP_METADATA=0


# =========================
# Operational controls
# =========================

# Write a SHA-256 checksum next to final output
#CHECKSUM=0

# Dry-run: plan the steps without generating real outputs
#DRY_RUN=0

# Skip processing if source already matches profile requirements
SKIP_IF_IDEAL=1

# Generate a JSON report alongside output
#REPORT_JSON=0


# =========================
# ffmpeg / ffprobe UX
# =========================

# Hide ffmpeg banner: 1 = hide  |  0 = show
#FFMPEG_HIDE_BANNER=1

# ffmpeg log level: quiet|panic|fatal|error|warning|info|verbose|debug|trace
#FFMPEG_LOGLEVEL=error

# Overwrite outputs without prompting
#FFMPEG_OVERWRITE=1

# ffprobe log level
#FFPROBE_LOGLEVEL=error
